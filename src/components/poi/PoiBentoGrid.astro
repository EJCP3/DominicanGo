---
import { Image } from "astro:assets";

const { images, name } = Astro.props;
---

<div
    class="grid grid-cols-3 grid-rows-2 gap-2.5 h-[340px] rounded-3xl overflow-hidden shadow-sm bg-base-200"
>
    <!-- Large: col-span-2, row-span-2 -->
    <button 
        type="button"
        class="block w-full h-full p-0 border-none appearance-none col-span-2 row-span-2 relative overflow-hidden bento-item cursor-zoom-in group text-left"
        onclick={`window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { img: '${images[0]}', alt: '${name} - Vista 1' } }))`}
        aria-label={`Ampliar imagen: ${name} - Vista 1`}
    >
        <Image
            src={images[0]}
            alt={`${name} - vista 1`}
            width={800}
            height={600}
            format="webp"
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
            class="bento-hover absolute inset-0 bg-black/20 opacity-0 transition-opacity duration-300 flex items-end p-4"
        >
            <span
                class="text-white text-xs font-semibold bg-black/40 backdrop-blur-sm px-2.5 py-1 rounded-full"
                >Vista 1</span
            >
        </div>
    </button>
    <!-- Small top-right -->
    <button 
        type="button"
        class="block w-full h-full p-0 border-none appearance-none col-span-1 row-span-1 relative overflow-hidden bento-item cursor-zoom-in group text-left"
        onclick={`window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { img: '${images[1]}', alt: '${name} - Vista 2' } }))`}
        aria-label={`Ampliar imagen: ${name} - Vista 2`}
    >
        <Image
            src={images[1]}
            alt={`${name} - vista 2`}
            width={400}
            height={300}
            format="webp"
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
            class="bento-hover absolute inset-0 bg-black/20 opacity-0 transition-opacity duration-300 flex items-end p-3"
        >
            <span
                class="text-white text-xs font-semibold bg-black/40 backdrop-blur-sm px-2 py-0.5 rounded-full"
                >Vista 2</span
            >
        </div>
    </button>
    <!-- Small bottom-right -->
    <button 
        type="button"
        class="block w-full h-full p-0 border-none appearance-none col-span-1 row-span-1 relative overflow-hidden bento-item cursor-zoom-in group text-left"
        onclick={`window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { img: '${images[2]}', alt: '${name} - Vista 3' } }))`}
        aria-label={`Ampliar imagen: ${name} - Vista 3`}
    >
        <Image
            src={images[2]}
            alt={`${name} - vista 3`}
            width={400}
            height={300}
            format="webp"
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
            class="bento-hover absolute inset-0 bg-black/20 opacity-0 transition-opacity duration-300 flex items-end p-3"
        >
            <span
                class="text-white text-xs font-semibold bg-black/40 backdrop-blur-sm px-2 py-0.5 rounded-full"
                >Vista 3</span
            >
        </div>
    </button>
</div>
<style>
    .bento-item:hover .bento-hover {
        opacity: 1;
    }
    .bento-item img {
        transition: transform 0.5s ease;
    }
    .bento-item:hover img {
        transform: scale(1.06);
    }
</style>
