---
// PoiSidebar.astro — sharing & quick-info sidebar
interface Props {
    poi: any;
    province: any;
    hours: any;
    website?: string | null;
    mapLink: string;
    showHours: boolean;
}
const { poi, province, hours, website, mapLink, showHours } = Astro.props;
const shareUrl = Astro.url.href;
const priceLabel = poi.price === "gratis" ? "Gratuito" : "Tiene costo";
---

<aside class="poi-sidebar">
    <div class="sidebar-card">
        <h3 class="sc-title">Información rápida</h3>
        <ul class="info-list">
            <li>
                <span class="info-icon">📍</span><span
                    ><strong>Provincia:</strong> {province.name}</span
                >
            </li>
            <li>
                <span class="info-icon">🏷️</span><span
                    ><strong>Categoría:</strong> {poi.type}</span
                >
            </li>
            <li>
                <span class="info-icon">💰</span><span
                    ><strong>Precio:</strong> {priceLabel}</span
                >
            </li>
        </ul>
    </div>

    {
        poi.tags && poi.tags.length > 0 && (
            <div class="sidebar-card">
                <h3 class="sc-title">Etiquetas</h3>
                <div class="tags-wrap">
                    {poi.tags.map((t: string) => (
                        <span
                            class="tag-pill"
                            style={`border-color:${province.color}44;color:${province.color}`}
                        >
                            {t}
                        </span>
                    ))}
                </div>
            </div>
        )
    }

    {
        showHours && (
            <div class="sidebar-card">
                <h3 class="sc-title">Horarios</h3>
                <ul class="info-list">
                    <li>
                        <>
                            <span class="info-icon">🕒</span>
                            <span>Lunes a Viernes: {hours.weekdays}</span>
                        </>
                    </li>
                    <li>
                        <>
                            <span class="info-icon">🕒</span>
                            <span>Fines de semana: {hours.weekend}</span>
                        </>
                    </li>
                </ul>
            </div>
        )
    }

    <div class="sidebar-card">
        <h3 class="sc-title">Explorar más</h3>
        <a
            href={mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="sidebar-link">🗺️ Ver en Google Maps</a
        >
        {
            website && (
                <a
                    href={website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="sidebar-link"
                >
                    🌐 Sitio Web Oficial
                </a>
            )
        }
        <a href={`/destinos`} class="sidebar-link">← Todos los destinos</a>
    </div>
</aside>

<style>
    .poi-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .sidebar-card {
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 16px;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .sc-title {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #4ade80;
        margin: 0;
    }
    .info-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .info-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        font-size: 0.82rem;
        color: #94a3b8;
    }
    .info-icon {
        font-size: 1rem;
        flex-shrink: 0;
    }
    .tags-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }
    .tag-pill {
        font-size: 0.72rem;
        font-weight: 600;
        border: 1px solid;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
    }
    .sidebar-link {
        display: block;
        font-size: 0.82rem;
        color: #64748b;
        text-decoration: none;
        padding: 0.3rem 0;
        transition: color 0.2s;
    }
    .sidebar-link:hover {
        color: #4ade80;
    }
</style>
