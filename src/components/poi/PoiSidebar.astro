---
// PoiSidebar.astro — sharing & quick-info sidebar
import Icon from "../Icon.astro";
interface Props {
    poi: any;
    province: any;
    hours: any;
    website?: string | null;
    mapLink: string;
    showHours: boolean;
}
const { poi, province, hours, website, mapLink, showHours } = Astro.props;
const shareUrl = Astro.url.href;
const priceLabel = poi.price === "gratis" ? "Gratuito" : "Tiene costo";
---

<aside class="poi-sidebar">
    <div class="sidebar-card">
        <h3 class="sc-title">Información rápida</h3>
        <ul class="info-list">
            <li>
             
                    <strong>Provincia:</strong> {province.name}</span
                >
            </li>
            <li>
               
                    <strong>Categoría:</strong> {poi.type}</span
                >
            </li>
            <li>
               
                    <strong>Precio:</strong> {priceLabel}</span
                >
            </li>
        </ul>
    </div>

    {
        poi.tags && poi.tags.length > 0 && (
            <div class="sidebar-card">
                <h3 class="sc-title">Etiquetas</h3>
                <div class="tags-wrap">
                    {poi.tags.map((t: string) => (
                        <span
                            class="tag-pill"
                            style={`border-color:${province.color}44;color:${province.color}`}
                        >
                            {t}
                        </span>
                    ))}
                </div>
            </div>
        )
    }

    {
        showHours && (
            <div class="sidebar-card">
                <h3 class="sc-title">Horarios</h3>
                <ul class="info-list">
                    <li>
                        <>
                            <span>Lunes a Viernes: {hours.weekdays}</span>
                        </>
                    </li>
                    <li>
                        <>
                            <span>Fines de semana: {hours.weekend}</span>
                        </>
                    </li>
                </ul>
            </div>
        )
    }

    <div class="sidebar-card">
        <h3 class="sc-title">Explorar más</h3>
        <a
            href={mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:underline text-error flex items-center gap-2"
        >   
     Ver en Google Maps<Icon name="arrow-right" />
        </a>
        {
            website && (
                <a
                    href={website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class=" flex items-center gap-2 hover:underline text-error"
                >
                   Sitio Web Oficial<Icon name="globe" />
                </a>
            )
        }
        <a href={`/destinos`} class=" flex items-center gap-2 hover:underline text-primary">
             <Icon name="arrow-left" /> Todos los destinos</a>
    </div>
</aside>

<style>
    @reference "../../styles/app.css";
    .poi-sidebar {
        @apply flex flex-col gap-4;
    }
    .sidebar-card {
        @apply bg-base-100 rounded-2xl p-5 flex flex-col gap-3 shadow-sm border border-base-200;
    }
    .sc-title {
        @apply text-xs font-bold uppercase tracking-wider text-primary m-0;
    }
    .info-list {
        @apply list-none m-0 p-0 flex flex-col gap-2;
    }
    .info-list li {
        @apply flex items-start gap-2 text-sm text-base-content/80;
    }
    .info-icon {
        @apply text-base shrink-0;
    }
    .tags-wrap {
        @apply flex flex-wrap gap-1.5;
    }
    .tag-pill {
        @apply text-[11px] font-semibold border px-2.5 py-1 rounded-full;
    }
    .sidebar-link {
        @apply block text-sm text-base-content/70 no-underline py-1 transition-colors;
    }
    .sidebar-link:hover {
        @apply text-primary;
    }
</style>
