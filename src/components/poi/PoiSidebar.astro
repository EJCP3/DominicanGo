---
// PoiSidebar.astro — sharing & quick-info sidebar
import Icon from "../ui/Icon.astro";
import SocialActions from "../interactions/SocialActions.vue";
import DeleteContentModal from "../ui/DeleteContentModal.vue";

interface Props {
    poi: any;
    province: any;
    hours: any;
    website?: string | null;
    mapLink: string;
    showHours: boolean;
    token: string;
    isLoggedIn: boolean;
    isFavorited: boolean;
    user?: any;
    loginUrl?: string;
}
const {
    poi,
    province,
    hours,
    website,
    mapLink,
    showHours,
    token,
    isLoggedIn,
    isFavorited,
    user,
    loginUrl,
} = Astro.props;
const shareUrl = Astro.url.href;
const priceLabel = poi.price === "gratis" ? "Gratuito" : "Tiene costo";
const seed = poi.id || poi.poiSlug || "";
const isOwner = user && poi.authorId && user.id === poi.authorId;
const isAdmin = user?.role?.toUpperCase() === 'ADMIN';
const canManage = isOwner || isAdmin;

// Check if within 1-hour edit window (non-admins only)
const canEdit = isAdmin || (isOwner && poi.createdAt && (Date.now() - new Date(poi.createdAt).getTime() < 60 * 60 * 1000));
---

<aside class="poi-sidebar">
    <!-- Main Info & Actions Card -->
    <div class="sidebar-card overflow-hidden p-0!">
        <div class="bg-primary/5 p-5 border-b border-primary/10">
            <h3
                class="text-xs font-bold uppercase tracking-widest text-neutral mb-4"
            >
                Información del Destino
            </h3>
            <ul class="flex flex-col gap-3.5">
                <li
                    class="flex items-center gap-3 text-sm font-medium text-base-content/80"
                >
                    <div
                        class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shadow-xs border border-base-200 shrink-0"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path></svg
                        >
                    </div>
                    <div class="flex flex-col">
                        <span
                            class="text-[10px] uppercase tracking-tighter text-base-content/40"
                            >Provincia</span
                        >
                        {province.name}
                    </div>
                </li>
                <li
                    class="flex items-center gap-3 text-sm font-medium text-base-content/80"
                >
                    <div
                        class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shadow-xs border border-base-200 shrink-0"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
                            ></path></svg
                        >
                    </div>
                    <div class="flex flex-col">
                        <span
                            class="text-[10px] uppercase tracking-tighter text-base-content/40"
                            >Categoría</span
                        >
                        <span class="capitalize">{poi.type}</span>
                    </div>
                </li>
                <li
                    class="flex items-center gap-3 text-sm font-medium text-base-content/80"
                >
                    <div
                        class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shadow-xs border border-base-200 shrink-0"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path></svg
                        >
                    </div>
                    <div class="flex flex-col">
                        <span
                            class="text-[10px] uppercase tracking-tighter text-base-content/40"
                            >Entrada</span
                        >
                        {priceLabel}
                    </div>
                </li>
            </ul>
        </div>

        <div class="px-5 py-6 bg-white border-t border-base-200">
            <SocialActions 
                client:load 
                targetType="DESTINATION" 
                targetId={poi.id} 
                token={token} 
                loginUrl={loginUrl}
                initialFavorited={isFavorited}
                title="¿Te gusta?"
                subtitle="Reacciona o compártelo."
            />
        </div>
    </div>

    <!-- Planning Card -->
    {
        showHours && (
            <div class="sidebar-card">
                <h3 class="sc-title text-neutral">Planifica tu visita</h3>
                <div class="flex flex-col gap-3 mt-1">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-warning/10 flex items-center justify-center text-warning shrink-0">
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] uppercase tracking-tighter text-base-content/40">
                                Semana
                            </span>
                            <span class="text-sm font-medium">
                                {hours.weekdays}
                            </span>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-warning/10 flex items-center justify-center text-warning shrink-0">
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] uppercase tracking-tighter text-base-content/40">
                                Fin de semana
                            </span>
                            <span class="text-sm font-medium">
                                {hours.weekend}
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        )
    }

    <!-- Navigation Card -->
    <div class="sidebar-card bg-base-100">
        <h3 class="font-heading font-bold text-base-content">Explorar más</h3>
        <div class="flex flex-col gap-2">
            <a
                href={mapLink}
                target="_blank"
                rel="noopener noreferrer"
                class="flex justify-center items-center rounded-xl h-12 border border-base-200 shadow-xs group"
            >
                <div
                    class="w-8 h-8 rounded-lg bg-error/10 flex items-center justify-center text-error mr-2 group-hover:scale-110 transition-transform"
                >
                    <svg
                        class="w-4 h-4 text-neutral"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 20l-5.447-2.724A2 2 0 013 15.485V5.414a2 2 0 012.553-1.907L10 5l5-2 5.447 2.724A2 2 0 0121 7.515v10.071a2 2 0 01-2.553 1.907L13 17l-4 3z"
                        ></path></svg
                    >
                </div>
                <span
                    class="text-sm font-bold text-base-content group-hover:text-secondary transition-colors"
                    >Ver en Google Maps</span
                >
            </a>

            {
                website && (
                    <a
                        href={website}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-ghost justify-start! rounded-xl! h-12!  border border-base-200 group"
                    >
                        <div class="w-8 h-8 rounded-lg bg-info/10 flex items-center justify-center text-info mr-2 group-hover:scale-110 transition-transform">
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"
                                />
                            </svg>
                        </div>
                        <span class="text-sm font-bold text-primary group-hover:text-secondary transition-colors">
                            Sitio Web Oficial
                        </span>
                    </a>
                )
            }

            <a
                href={`/destinos`}
                class="flex items-center justify-center gap-2 mt-2 py-3 text-xs font-bold text-neutral/80 hover:text-secondary transition-colors no-underline"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
                >
            </a>
        </div>
    </div>


    <!-- Owner/Admin Actions Card -->
    {canManage && poi.id && (
        <div class="sidebar-card p-0! overflow-hidden">
            <div class="px-5 py-3.5 border-b border-base-200 flex items-center gap-2.5">
                <div class="w-6 h-6 rounded-lg bg-neutral/8 flex items-center justify-center">
                    <svg class="w-3 h-3 text-neutral/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <span class="text-[10px] font-bold uppercase tracking-widest text-base-content/40">Gestión del autor</span>
            </div>
            <div class="p-4 flex flex-col gap-2">
                {canEdit && (
                    <a
                        href={`/destinos/editar/${poi.id}`}
                        class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl text-sm font-semibold bg-base-100 hover:bg-base-200 text-base-content/70 hover:text-base-content transition-all border border-base-200"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Editar destino
                    </a>
                )}

                <DeleteContentModal
                    client:load
                    show={false}
                    resourceId={poi.id}
                    resourceType="destination"
                    resourceTitle={poi.name}
                    token={token}
                />
                <button
                    id="btn-delete-destination"
                    type="button"
                    class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl text-sm font-semibold text-error bg-error/5 hover:bg-error/10 border border-error/15 hover:border-error/30 transition-all"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Eliminar destino
                </button>
            </div>
        </div>
    )}
</aside>

<script>
    // Wires up the delete button to the Vue modal
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('btn-delete-destination');
        if (!btn) return;
        // Find the Vue modal component wrapper and trigger its show state via a custom event
        btn.addEventListener('click', () => {
            document.dispatchEvent(new CustomEvent('open-delete-modal'));
        });
    });
</script>

<style>
    @reference "../../styles/app.css";
    .poi-sidebar {
        @apply flex flex-col gap-4;
    }
    .sidebar-card {
        @apply bg-base-100 rounded-2xl p-5 flex flex-col gap-3 shadow-sm border border-base-200;
    }
    .sc-title {
        @apply text-xs font-bold uppercase tracking-wider text-neutral m-0;
    }
    .info-list {
        @apply list-none m-0 p-0 flex flex-col gap-2;
    }
    .info-list li {
        @apply flex items-start gap-2 text-sm text-base-content/80;
    }
    .info-icon {
        @apply text-base shrink-0;
    }
    .tags-wrap {
        @apply flex flex-wrap gap-1.5;
    }
    .tag-pill {
        @apply text-[11px] font-semibold border px-2.5 py-1 rounded-full;
    }
    .sidebar-link {
        @apply block text-sm text-neutral/70 no-underline py-1 transition-colors;
    }
    .sidebar-link:hover {
        @apply text-neutral;
    }
</style>
