---
// Header — auth-aware with Bearer token login/user dropdown
import ThemeDropdown from "./header/ThemeDropdown.astro";
import MobileMenu from "./header/MobileMenu.astro";
import ThemeScript from "./header/ThemeScript.astro";
import { getUser } from "../../services/api";
import Icon from "../ui/Icon.astro";

const currentPath = Astro.url.pathname;
const isHomeOrDestinos = currentPath === "/" || currentPath.startsWith("/destinos");

// Read JWT from cookie and validate with backend
const token = Astro.cookies.get("auth_token")?.value;
const user = await getUser(token);

const API_BASE = import.meta.env.PUBLIC_API_URL?.replace('/api', '') || 'http://localhost:3000';
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md no-underline">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
        <!-- Logo -->
        <div class="flex items-center gap-2">
            <a
                href="/"
                class="no-underline font-heading font-extrabold text-neutral text-lg sm:text-xl transition-all hover:opacity-80"
            >
                Dominican<span class="text-success font-extrabold text-2xl">Go</span>
            </a>
        </div>

        <!-- Nav links (Desktop) -->
        <nav class="hidden md:flex items-center gap-1 relative px-1 py-1 rounded-full" id="desktop-nav">
            <!-- Sliding Highlighter -->
            <div id="header-highlighter" class="absolute h-[calc(100%-8px)] top-1 left-1 bg-primary rounded-full z-0 pointer-events-none shadow-[0_4px_12px_rgba(var(--p),0.3)] opacity-0 transition-opacity"></div>

            <a
                href="/"
                class={`nav-link relative z-10 no-underline px-5 py-1.5 rounded-full text-sm font-bold transition-colors duration-300 ${
                    isHomeOrDestinos
                        ? "text-primary-content active-nav"
                        : "text-base-content/60 hover:text-base-content"
                }`}
            >
                Destinos
            </a>
            <a
                href="/blog"
                class={`nav-link relative z-10 no-underline px-5 py-1.5 rounded-full text-sm font-bold transition-colors duration-300 ${
                    currentPath.startsWith("/blog")
                        ? "text-primary-content active-nav"
                        : "text-base-content/60 hover:text-base-content"
                }`}
            >
                Blog
            </a>
           
        </nav>

        <!-- Right Side Actions -->
        <div class="flex items-center gap-2 sm:gap-3">
            {user ? (
                <>
                    <!-- Avatar dropdown: desktop only. Mobile uses MobileMenu -->
                    <div class="hidden md:block">
                    <div class="dropdown dropdown-end z-100">
                        <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
                            <div class="w-9 rounded-full ring ring-primary ring-offset-base-100 ring-offset-1">
                                {user.foto
                                    ? <img alt={user.name} src={user.foto} referrerpolicy="no-referrer" />
                                    : <div class="bg-primary text-primary-content flex items-center justify-center w-full h-full text-sm font-bold rounded-full select-none">{user.name?.charAt(0).toUpperCase()}</div>
                                }
                            </div>
                        </div>
                        <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-100 p-2 shadow-xl bg-base-100 rounded-2xl w-60 border border-base-200">
                            <li class="menu-title px-2 py-1">
                                <span class="font-semibold text-sm text-base-content truncate">{user.name}</span>
                            </li>
                            <div class="divider my-0.5"></div>
                            <li>
                                <a href="/favoritos">
                                    <svg class="w-4 h-4 text-error" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                                    Mis Favoritos
                                </a>
                            </li>
                            <li>
                                <a href="/destinos/nuevo">
                                    <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                                    Registrar Destino
                                </a>
                            </li>
                            
                            <div class="divider my-0.5"></div>
                            <li class="menu-title px-2"><span class="text-xs">Estaciones (Tema)</span></li>
                            <li>
                                <button data-theme-btn="pastel" class="theme-btn">
                                    <Icon name="spring" class="w-4 h-4 opacity-70" /> Primavera
                                </button>
                            </li>
                            <li>
                                <button data-theme-btn="cupcake" class="theme-btn">
                                    <Icon name="summer" class="w-4 h-4 opacity-70" /> Verano
                                </button>
                            </li>
                            <li>
                                <button data-theme-btn="caramellatte" class="theme-btn">
                                    <Icon name="autumn" class="w-4 h-4 opacity-70" /> Otoño
                                </button>
                            </li>
                            <li>
                                <button data-theme-btn="nord" class="theme-btn">
                                    <Icon name="winter" class="w-4 h-4 opacity-70" /> Invierno
                                </button>
                            </li>

                            <div class="divider my-0.5"></div>
                            <li>
                                <a href="/logout" class="text-error font-medium">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                                    Cerrar sesión
                                </a>
                            </li>
                        </ul>
                    </div>
                    </div>
                </>
            ) : (
                /* Logged out: Google Sign-In (desktop only — mobile uses MobileMenu) */
                <>
                    <a
                        href={`${API_BASE}/auth/google`}
                        class="hidden md:inline-flex btn btn-primary btn-sm rounded-full shadow-sm gap-2"
                    >
                        <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                        Iniciar sesión
                    </a>
                    <ThemeDropdown />
                </>
            )}

            <MobileMenu user={user} apiBase={API_BASE} />
        </div>
    </div>
</header>
<ThemeScript />

<script>
    import { gsap } from "gsap";

    function updateHeaderHighlighter() {
        const highlighter = document.getElementById('header-highlighter');
        const activeLink = document.querySelector('#desktop-nav a.active-nav');
        
        if (!highlighter || !activeLink) return;

        gsap.set(highlighter, { opacity: 1 });

        // Calculamos x considerando el 'left-1' (4px) del highlighter
        gsap.to(highlighter, {
            x: activeLink.offsetLeft - 4,
            width: activeLink.offsetWidth,
            duration: 0.4,
            ease: "power2.out",
            overwrite: "auto"
        });
    }

    function setupHeaderTransitions() {
        const navLinks = document.querySelectorAll('#desktop-nav a.nav-link');
        
        navLinks.forEach(link => {
            const clone = link.cloneNode(true);
            link.parentNode?.replaceChild(clone, link);

            clone.addEventListener('click', (e) => {
                if (clone.classList.contains('active-nav')) return;

                // Respuesta visual inmediata
                document.querySelectorAll('#desktop-nav a.nav-link').forEach(l => {
                    l.classList.remove('active-nav', 'text-primary-content');
                    l.classList.add('text-base-content/60');
                });
                
                clone.classList.remove('text-base-content/60');
                clone.classList.add('active-nav', 'text-primary-content');
                
                updateHeaderHighlighter();
            });
            
            // Efecto Magneto / Hover flotante 
            clone.addEventListener('mouseenter', () => {
                const highlighter = document.getElementById('header-highlighter');
                if (highlighter && !clone.classList.contains('active-nav')) {
                     gsap.to(highlighter, {
                        x: clone.offsetLeft - 4,
                        width: clone.offsetWidth,
                        duration: 0.3,
                        ease: "power2.out",
                        opacity: 0.6, // Tenue en hover para resaltar
                        overwrite: "auto"
                    });
                }
            });
            
            clone.addEventListener('mouseleave', () => {
                 const activeLink = document.querySelector('#desktop-nav a.active-nav');
                 if (activeLink) {
                     const highlighter = document.getElementById('header-highlighter');
                     gsap.to(highlighter, {
                        x: activeLink.offsetLeft - 4,
                        width: activeLink.offsetWidth,
                        opacity: 1, // Vuelve a sólido cuando regresa al activo
                        duration: 0.3,
                        ease: "power2.out",
                        overwrite: "auto"
                    });
                 }
            });
        });
    }

    document.addEventListener('astro:page-load', () => {
        const highlighter = document.getElementById('header-highlighter');
        if (highlighter) {
             const activeLink = document.querySelector('#desktop-nav a.active-nav');
             if (activeLink) {
                 // Posicionamiento instantáneo en la carga para evitar 'saltos'
                 gsap.set(highlighter, {
                     x: activeLink.offsetLeft - 4,
                     width: activeLink.offsetWidth,
                     opacity: 1
                 });
             } else {
                 gsap.set(highlighter, { opacity: 0 }); 
             }
        }
        setupHeaderTransitions();
    });
</script>
