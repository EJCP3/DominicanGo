>
    <div
        class="px-4 md:px-6 flex flex-col md:flex-row items-center justify-center md:justify-between gap-4 md:gap-0 text-center md:text-left text-[10px] text-base-content/50 tracking-widest uppercase max-w-[1400px] w-full mx-auto"
    >
        <span class="flex flex-col sm:flex-row items-center gap-2">
            <Icon name="map" class="w-3 h-3 hidden sm:inline-block" />
            Guía Turística Interactiva de República Dominicana &hearts;
        </span>
        <span>&copy; 2026 DominicanGo</span>
    </div>
</footer>
