---
import { TYPE_LABELS } from "../../data/poi-config.ts";

interface DestinoItem {
    name: string;
    description: string;
    type: string;
    price: string;
    tags?: string[];
    image: string;
    province: string;
    provinceSlug: string;
    provinceColor: string;
    region: string;
    href: string;
}
interface Props {
    d: DestinoItem;
}
const { d } = Astro.props;
---

<article
    class="destino-card group bg-white/90 rounded-2xl overflow-hidden border border-white/70 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 cursor-pointer"
    data-name={d.name.toLowerCase()}
    data-description={d.description.toLowerCase()}
    data-tipo={d.type}
    data-provincia={d.provinceSlug}
    data-region={d.region}
    data-precio={d.price}
    data-tags={(d.tags ?? []).join(",")}
    data-href={d.href}
    data-modal-name={d.name}
    data-modal-desc={d.description}
    data-modal-province={d.province}
    data-modal-province-color={d.provinceColor}
    data-modal-region={d.region}
    data-modal-price={d.price}
    data-modal-type={d.type}
    data-modal-image={d.image}
    data-modal-tags={(d.tags ?? []).join(",")}
>
    <div class="relative h-44 overflow-hidden bg-gray-100">
        <img
            src={d.image}
            alt={d.name}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        <!-- Type badge -->
        <div class="absolute top-3 left-3">
            <span
                class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-semibold bg-white/90 backdrop-blur-sm text-gray-700 shadow-sm card-type-badge"
                data-type={d.type}
            >
                <span class="w-3.5 h-3.5 card-icon"></span>
                {TYPE_LABELS[d.type] ?? d.type}
            </span>
        </div>
        <!-- Price badge -->
        <div class="absolute top-3 right-3">
            <span
                class={`px-2.5 py-1 rounded-full text-[10px] font-bold shadow-sm ${d.price === "gratis" ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700"}`}
            >
                {d.price === "gratis" ? "GRATIS" : "PAGADO"}
            </span>
        </div>
    </div>
    <div class="p-4">
        <div class="flex items-center gap-2 mb-2">
            <span
                class="w-2 h-2 rounded-full shrink-0"
                style={`background:${d.provinceColor}`}></span>
            <span
                class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider"
                >{d.province}</span
            >
            <span class="text-[11px] text-gray-300">·</span>
            <span class="text-[11px] text-gray-400">{d.region}</span>
        </div>
        <h3
            class="font-heading font-bold text-gray-800 text-base mb-1 leading-tight group-hover:text-sky-600 transition-colors line-clamp-1"
        >
            {d.name}
        </h3>
        <p class="text-gray-500 text-xs leading-relaxed line-clamp-2 mb-3">
            {d.description}
        </p>
        <div class="flex flex-wrap gap-1">
            {
                (d.tags ?? [])
                    .slice(0, 3)
                    .map((tag: string) => (
                        <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 text-[10px] font-medium">
                            #{tag}
                        </span>
                    ))
            }
        </div>
    </div>
</article>

<style>
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
