---
import { TIPOS, TYPE_LABELS, ICONS } from "../../data/poi-config.ts";

interface DestinoItem {
    name: string;
    description: string;
    type: string;
    price: string;
    tags?: string[];
    image: string;
    images?: string[];
    province: string;
    provinceSlug: string;
    poiSlug: string;
    provinceColor: string;
    region: string;
    href: string;
    id?: string;
}
interface Props {
    d: DestinoItem;
    token?: string;
    initialFavorited?: boolean;
}
const { d, token = "", initialFavorited = false } = Astro.props;
---

<a
    href={d.href}
    class="destino-card group block bg-base-100/90 rounded-2xl overflow-hidden border border-base-content/10 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 cursor-pointer"
    data-name={d.name.toLowerCase()}
    data-description={d.description.toLowerCase()}
    data-tipo={d.type}
    data-provincia={d.provinceSlug}
    data-region={d.region}
    data-precio={d.price}
    data-tags={(d.tags ?? []).join(",")}
    data-href={d.href}
    data-modal-name={d.name}
    data-modal-desc={d.description}
    data-modal-province={d.province}
    data-modal-province-color={d.provinceColor}
    data-modal-region={d.region}
    data-modal-price={d.price}
    data-modal-type={d.type}
    data-modal-image={d.image}
    data-modal-images={d.images
        ? [d.image, ...d.images.filter((img: string) => img !== d.image)].join(
              ",",
          )
        : ""}
    data-modal-tags={(d.tags ?? []).join(",")}
>
    <div
        class="relative h-44 bg-base-300 overflow-hidden group/card rounded-t-2xl"
        transition:name={`img-destino-${d.provinceSlug}-${d.poiSlug}`}
    >
        <figure class="w-full h-full m-0">
            <img
                src={d.image}
                alt={d.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
        </figure>
        <!-- Type badge -->
        <div class="absolute top-3 left-3 z-10 pointer-events-none">
            <span
                class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-semibold bg-accent/70 backdrop-blur-md text-accent-content border border-accent/20 shadow-sm card-type-badge"
                data-type={d.type}
            >
                <span
                    class="w-3.5 h-3.5 card-icon flex items-center justify-center shrink-0"
                    set:html={ICONS[d.type]}
                />
                {TYPE_LABELS[d.type] ?? d.type}
            </span>
        </div>
        <!-- Price badge (bottom-left to avoid overlapping heart) -->
        <div class="absolute top-3 right-3 z-10 pointer-events-none">
            <span
                class={`badge badge-sm font-bold shadow-sm ${d.price === "gratis" ? "badge-success" : "badge-warning"}`}
            >
                {d.price === "gratis" ? "GRATIS" : "PAGADO"}
            </span>
        </div>
    </div>
    <div class="p-4">
        <div class="flex items-center gap-2 mb-2">
            <span
                class="w-2 h-2 rounded-full shrink-0"
                style={`background:${d.provinceColor}`}></span>
            <span
                class="text-[11px] font-semibold text-base-content/50 uppercase tracking-wider"
                >{d.province}</span
            >
            <span class="text-[11px] text-base-content/30">·</span>
            <span class="text-[11px] text-base-content/50">{d.region}</span>
        </div>
        <h3
            class="font-heading font-bold text-base-content text-base mb-1 leading-tight group-hover:text-primary transition-colors line-clamp-1"
        >
            {d.name}
        </h3>
        <p
            class="text-base-content/70 text-xs leading-relaxed line-clamp-2 mb-3"
        >
            {d.description}
        </p>
        <div class="flex flex-wrap gap-1">
            {
                (d.tags ?? [])
                    .slice(0, 3)
                    .map((tag: string) => (
                        <span class="px-2 py-0.5 rounded-full bg-base-200 text-base-content/70 text-[10px] font-medium">
                            {tag}
                        </span>
                    ))
            }
        </div>
    </div>
</a>

<style>
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-icon :global(svg) {
        width: 100%;
        height: 100%;
    }
</style>
