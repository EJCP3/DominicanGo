---
// DestinoCardSkeleton — animated placeholder para mientras cargan los destinos
---

<div class="bg-base-100/90 rounded-2xl overflow-hidden border border-base-content/10 shadow-sm animate-pulse">
    <!-- Image placeholder -->
    <div class="h-44 bg-base-300 rounded-t-2xl relative overflow-hidden">
        <!-- shimmer effect -->
        <div class="absolute inset-0 -translate-x-full bg-linear-to-r from-transparent via-base-100/30 to-transparent skeleton-shimmer"></div>
        <!-- badge placeholders -->
        <div class="absolute top-3 left-3 h-6 w-20 rounded-full bg-base-200/80"></div>
        <div class="absolute top-3 right-3 h-5 w-14 rounded-full bg-base-200/80"></div>
    </div>
    <!-- Content placeholder -->
    <div class="p-4 space-y-3">
        <!-- Province line -->
        <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-base-300 shrink-0"></div>
            <div class="h-3 w-24 rounded-full bg-base-300"></div>
            <div class="h-3 w-1 rounded-full bg-base-200"></div>
            <div class="h-3 w-16 rounded-full bg-base-200"></div>
        </div>
        <!-- Title -->
        <div class="h-4 w-4/5 rounded-full bg-base-300"></div>
        <!-- Description lines -->
        <div class="space-y-2">
            <div class="h-3 w-full rounded-full bg-base-200"></div>
            <div class="h-3 w-3/4 rounded-full bg-base-200"></div>
        </div>
        <!-- Tags -->
        <div class="flex gap-1.5 pt-1">
            <div class="h-5 w-14 rounded-full bg-base-200"></div>
            <div class="h-5 w-16 rounded-full bg-base-200"></div>
            <div class="h-5 w-12 rounded-full bg-base-200"></div>
        </div>
    </div>
</div>

<style>
.skeleton-shimmer {
    animation: shimmer 1.8s infinite;
}
@keyframes shimmer {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(300%); }
}
</style>
