---
interface Props {
    totalCount: number;
    provinceCount: number;
}
const { totalCount, provinceCount } = Astro.props;
---

<div class="pt-12 pb-8 px-6 text-center">
    <p
        class="text-xs uppercase tracking-[0.3em] text-success font-semibold mb-2"
    >
        República Dominicana
    </p>
    <h1 class="font-heading font-bold text-4xl md:text-5xl text-base-content mb-3">
        Explora los <span
            class="text-secondary"
            >Destinos</span
        >
    </h1>
    <p class="text-base-content/70 max-w-xl mx-auto text-base">
        {totalCount} lugares increíbles en {provinceCount} provincias — filtra, busca
        y descubre tu próxima aventura.
    </p>
</div>
