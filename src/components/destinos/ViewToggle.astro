---
// src/components/ViewToggle.astro
const currentPath = Astro.url.pathname;
const isMapActive = currentPath === '/' || currentPath === '/index';
const isGridActive = currentPath.startsWith('/destinos');

// Opcional: Solo mostrar el toggle en las rutas principales (Mapa o Grid)
const showToggle = currentPath === '/' || currentPath === '/index' || currentPath.startsWith('/destinos');
---

{showToggle && (
<nav id="view-toggle-bar" transition:persist class="fixed bottom-8 left-1/2 -translate-x-1/2 z-100 bg-white/80 backdrop-blur-xl p-1.5 rounded-full shadow-[0_12px_40px_rgba(0,0,0,0.15)] border border-white/20 flex items-center group transition-transform duration-500 hover:scale-105">
    
    <!-- Sliding Highlighter -->
    <div id="toggle-highlighter" class="absolute h-[calc(100%-12px)] top-1.5 left-1.5 bg-primary rounded-full shadow-[0_4px_16px_rgba(var(--p),0.4)] z-0 pointer-events-none"></div>

    <!-- Botón Mapa -->
    <a 
        href="/" 
        id="toggle-btn-map"
        class={`toggle-btn relative z-10 flex items-center justify-center gap-2 px-8 py-2.5 rounded-full text-sm font-bold transition-colors duration-300 ${
            isMapActive 
            ? 'text-base-content' 
            : 'text-base-content/40 hover:text-base-content/70'
        }`}
        aria-label="Vista de Mapa"
    >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        <span>Mapa</span>
    </a>
    
    <!-- Botón Grid (Destinos) -->
    <a 
        href="/destinos" 
        id="toggle-btn-grid"
        class={`toggle-btn relative z-10 flex items-center justify-center gap-2 px-8 py-2.5 rounded-full text-sm font-bold transition-colors duration-300 ${
            isGridActive 
            ? 'text-base-content' 
            : 'text-base-content/40 hover:text-base-content/70'
        }`}
        aria-label="Vista de Cuadrícula"
    >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
        <span>Grid</span>
    </a>

</nav>
)}

<script>
    import { gsap } from "gsap";
    import { navigate } from "astro:transitions/client";

    function moveHighlighterTo(activeBtn, anim = true) {
        const highlighter = document.getElementById('toggle-highlighter');
        if (!highlighter || !activeBtn) return;

        gsap.to(highlighter, {
            x: activeBtn.offsetLeft - 6,
            width: activeBtn.offsetWidth,
            duration: anim ? 0.4 : 0,
            ease: "power2.out",
            overwrite: "auto"
        });
    }

    // Configura las transiciones de las páginas (animación fuera/dentro)
    function setupToggleTransitions() {
        const toggleBtns = document.querySelectorAll('#view-toggle-bar a.toggle-btn');
        
        toggleBtns.forEach(btn => {
            // Limpia eventos anteriores reconstruyendo el botón
            const clone = btn.cloneNode(true);
            btn.parentNode?.replaceChild(clone, btn);

            clone.addEventListener('click', (e) => {
                const targetHref = clone.getAttribute('href');
                const targetPath = new URL(targetHref, window.location.origin).pathname;
                const currentPath = window.location.pathname;
                
                if (currentPath === targetPath || (currentPath === '/index' && targetPath === '/')) {
                    e.preventDefault();
                    return;
                }
                e.preventDefault();
                
                // 1. Dar respuesta visual inmediata (clases CSS y mover burbuja azul)
                document.querySelectorAll('#view-toggle-bar a.toggle-btn').forEach(b => {
                    b.classList.remove('text-white');
                    b.classList.add('text-base-content/40', 'hover:text-base-content/70');
                });
                clone.classList.add('text-white');
                clone.classList.remove('text-base-content/40', 'hover:text-base-content/70');
                moveHighlighterTo(clone, true);

                // 2. Animar contenido saliente
                const content = document.querySelector('section#mapa') || document.querySelector('main');
                if (content) {
                    gsap.to(content, {
                        y: 40,
                        opacity: 0,
                        duration: 0.15,
                        ease: "power1.in",
                        onComplete: () => {
                            sessionStorage.setItem('toggleTransition', 'true');
                            navigate(targetHref);
                        }
                    });
                } else {
                    sessionStorage.setItem('toggleTransition', 'true');
                    navigate(targetHref);
                }
            });
        });
    }

    // Inicialización y manejo de Astro Page Load
    document.addEventListener('astro:page-load', () => {
        // En cada carga de página asume el botón basado en URL (por si se navega sin el toggle)
        const isMap = window.location.pathname === '/' || window.location.pathname === '/index';
        const activeBtn = document.getElementById(isMap ? 'toggle-btn-map' : 'toggle-btn-grid');
        
        // Colocar la burbuja. Si venimos de un toggle manual, se asume que ya está en posición (anim=false) para no saltar.
        moveHighlighterTo(activeBtn, !sessionStorage.getItem('toggleTransition'));
        setupToggleTransitions();

        // Animar la entrada si venimos del Toggle
        if (sessionStorage.getItem('toggleTransition')) {
            sessionStorage.removeItem('toggleTransition');
            
            const content = document.querySelector('section#mapa') || document.querySelector('main');
            if (content) {
                // Como en tu codepen: cae desde arriba suavemente
                gsap.fromTo(content, 
                    { y: -60, opacity: 0 },
                    { y: 0, opacity: 1, duration: 0.70, ease: "power3.out", clearProps: "all" }
                );
            }
        }
    });

    // Carga inicial 
    if (!window.localStorage.getItem('toggle_initial_set')) {
        const isMap = window.location.pathname === '/' || window.location.pathname === '/index';
        const activeBtn = document.getElementById(isMap ? 'toggle-btn-map' : 'toggle-btn-grid');
        moveHighlighterTo(activeBtn, false);
        window.localStorage.setItem('toggle_initial_set', 'true');
    }
</script>
