---
import { TYPE_LABELS, REGION_COLORS, TIPOS } from "../../data/poi-config.ts";
import { provinces } from "../../data/provinces.js";
import Icon from "../Icon.astro";

const regiones = [
    ...new Set(Object.values(provinces).map((p: any) => p.region)),
].sort();
---

<aside class="lg:w-72 shrink-0">
    <div class="sticky top-24 space-y-6 max-h-[calc(100vh-7rem)] overflow-y-auto custom-scroll pb-6 pr-2">
        <!-- Buscar -->
        <div
            class="bg-base-100/85 backdrop-blur-md rounded-2xl border border-base-content/10 shadow-sm p-4"
        >
            <label
                class="text-xs uppercase tracking-wider text-base-content/50 font-semibold block mb-2"
                >Buscar</label
            >
            <div class="relative">
                <Icon name="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-base-content/50" />
                <input
                    id="search-input"
                    type="text"
                    placeholder="Playa Bávaro, cuevas, museo..."
                    class="w-full pl-9 pr-3 py-2.5 rounded-xl bg-base-200 border border-base-300 text-sm text-base-content placeholder-base-content/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition"
                />
            </div>
        </div>

        <!-- Tipo de Lugar -->
        <div
            class="bg-base-100/85 backdrop-blur-md rounded-2xl border border-base-content/10 shadow-sm p-4"
        >
            <label
                class="text-xs uppercase tracking-wider text-base-content/50 font-semibold block mb-3"
                >Tipo de Lugar</label
            >
            <div class="space-y-1" id="filter-tipo">
                {
                    TIPOS.map((tipo) => (
                        <button
                            data-filter="tipo"
                            data-value={tipo}
                            class="filter-btn w-full flex items-center gap-2.5 px-3 py-2 rounded-xl text-sm text-base-content/80 hover:bg-primary/10 hover:text-primary transition-all text-left"
                        >
                            <span
                                class="w-5 h-5 shrink-0 text-base-content/50 icon-svg"
                                data-icon={tipo}
                            />
                            <span class="font-medium">{TYPE_LABELS[tipo]}</span>
                            <span
                                class="ml-auto text-xs bg-accent/10 text-accent font-semibold rounded-full px-1.5 py-0.5 count-badge"
                                data-count={tipo}
                            />
                        </button>
                    ))
                }
            </div>
        </div>

        <!-- Provincia -->
        <div
            class="bg-base-100/85 backdrop-blur-md rounded-2xl border border-base-content/10 shadow-sm p-4"
        >
            <label
                class="text-xs uppercase tracking-wider text-base-content/50 font-semibold block mb-3"
                >Provincia</label
            >
            <div
                class="space-y-0.5 max-h-56 overflow-y-auto custom-scroll"
                id="filter-provincia"
            >
                {
                    Object.entries(provinces)
                        .sort((a: any, b: any) =>
                            a[1].name.localeCompare(b[1].name),
                        )
                        .map(([slug, prov]: any) => (
                            <button
                                data-filter="provincia"
                                data-value={slug}
                                class="filter-btn w-full flex items-center gap-2.5 px-3 py-1.5 rounded-xl text-sm text-base-content/80 hover:bg-primary/10 hover:text-primary transition-all text-left"
                            >
                                <span
                                    class="w-2.5 h-2.5 rounded-full shrink-0"
                                    style={`background:${prov.color}`}
                                />
                                <span class="font-medium truncate">
                                    {prov.name}
                                </span>
                            </button>
                        ))
                }
            </div>
        </div>

        <!-- Región -->
        <div
            class="bg-base-100/85 backdrop-blur-md rounded-2xl border border-base-content/10 shadow-sm p-4"
        >
            <label
                class="text-xs uppercase tracking-wider text-base-content/50 font-semibold block mb-3"
                >Región</label
            >
            <div class="flex flex-wrap gap-2" id="filter-region">
                {
                    regiones.map((region: string) => (
                        <button
                            data-filter="region"
                            data-value={region}
                            style={`border-color:${REGION_COLORS[region] ?? "#cbd5e1"}`}
                            class="filter-btn px-3 py-1.5 rounded-full text-xs font-semibold text-base-content/80 border-2 hover:text-base-content transition-all"
                        >
                            {region}
                        </button>
                    ))
                }
            </div>
        </div>

        <!-- Precio -->
        <div
            class="bg-base-100/85 backdrop-blur-md rounded-2xl border border-base-content/10 shadow-sm p-4"
        >
            <label
                class="text-xs uppercase tracking-wider text-base-content/50 font-semibold block mb-3"
                >Precio</label
            >
            <div class="flex gap-2" id="filter-precio">
                <button
                    data-filter="precio"
                    data-value="gratis"
                    class="filter-btn flex-1 flex items-center justify-center gap-1.5 py-2 rounded-xl text-sm font-medium text-base-content border border-base-300 hover:border-success hover:bg-success/10 hover:text-success transition-all"
                >
                    <Icon name="check" class="w-4 h-4" />
                    Gratis
                </button>
                <button
                    data-filter="precio"
                    data-value="pagado"
                    class="filter-btn flex-1 flex items-center justify-center gap-1.5 py-2 rounded-xl text-sm font-medium text-base-content border border-base-300 hover:border-warning hover:bg-warning/10 hover:text-warning transition-all"
                >
                    <Icon name="cash" class="w-4 h-4" />
                    Pagado
                </button>
            </div>
        </div>

        <!-- Reset -->
        <button
            id="reset-filters"
            class="w-full py-2.5 rounded-xl text-sm font-medium text-error/70 hover:text-error border border-dashed border-error/30 hover:border-error/60 hover:bg-error/5 transition-all hidden"
        >
            Limpiar filtros
        </button>
    </div>
</aside>

<style>
    @reference "../../styles/app.css";
    .filter-btn.active {
        @apply bg-primary/20 text-primary-content font-semibold border-primary/20;
    }
    .filter-btn[data-filter="precio"].active[data-value="gratis"] {
        @apply bg-success/20 text-success-content border-success;
    }
    .filter-btn[data-filter="precio"].active[data-value="pagado"] {
        @apply bg-warning/20 text-warning-content border-warning;
    }
    .custom-scroll::-webkit-scrollbar {
        width: 3px;
    }
    .custom-scroll::-webkit-scrollbar-thumb {
        @apply bg-base-300 rounded-full;
    }
</style>
