---
import { TYPE_LABELS, REGION_COLORS, TIPOS } from "../../data/poi-config.ts";
import { getProvincesWithDestinations } from "../../services/api";
const provinces = await getProvincesWithDestinations();

const regiones = [
    ...new Set(Object.values(provinces).map((p: any) => p.region)),
].sort();
---

<div
    id="filtros-panel"
    class="invisible opacity-0 scale-95 pointer-events-none origin-right transition-all duration-300 ease-out absolute top-30 right-0 -translate-y-1/2 w-[calc(100vw-2rem)] sm:w-[500px] z-50 bg-[#fdfcfa] border border-[#f0e6d2] shadow-2xl rounded-3xl p-6"
>
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <h3 class="font-heading font-extrabold text-xl text-base-content">
            Filtros
        </h3>

        <div class="flex items-center gap-2">
            <button
                id="reset-filters"
                class="btn btn-sm btn-circle btn-ghost text-base-content/60"
                title="Limpiar filtros"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                    ></path></svg
                >
            </button>
            <button
                class="btn btn-sm btn-circle btn-ghost text-base-content/60"
                onclick="document.getElementById('filtros-panel').classList.remove('popup-open');"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path></svg
                >
            </button>
        </div>
    </div>

    <!-- Body Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Left Column: Selects -->
        <div class="space-y-5">
            <div>
                <label
                    class="text-sm text-base-content/60 font-medium block mb-2 px-1"
                    >Categoría del destino</label
                >
                <select
                    id="filter-select-tipo"
                    class="select select-bordered select-md w-full bg-base-200/50 border-none rounded-2xl text-base-content font-medium focus:ring-2 focus:ring-primary/20 focus:outline-none"
                >
                    <option value="">Todos</option>
                    {
                        TIPOS.map((tipo) => (
                            <option value={tipo}>{TYPE_LABELS[tipo]}</option>
                        ))
                    }
                </select>
            </div>

            <div>
                <label
                    class="text-sm text-base-content/60 font-medium block mb-2 px-1"
                    >Provincia</label
                >
                <select
                    id="filter-select-provincia"
                    class="select select-bordered select-md w-full bg-base-200/50 border-none rounded-2xl text-base-content font-medium focus:ring-2 focus:ring-primary/20 focus:outline-none"
                >
                    <option value="">Todas</option>
                    {
                        Object.entries(provinces)
                            .sort((a: any, b: any) =>
                                a[1].name.localeCompare(b[1].name),
                            )
                            .map(([slug, prov]: any) => (
                                <option value={slug}>{prov.name}</option>
                            ))
                    }
                </select>
            </div>
        </div>

        <!-- Right Column: Warm Cards -->
        <div class="space-y-5">
            <!-- Región Cards (Warm styling) -->
            <div class="bg-[#FFFDF9] rounded-2xl p-4 border border-[#F2E8DA]">
                <h4
                    class="text-xs font-extrabold tracking-widest text-[#B58C73] uppercase mb-4"
                >
                    Región
                </h4>
                <div class="flex flex-wrap gap-2.5" id="filter-region">
                    {
                        regiones.map((region: string) => {
                            const borderColor =
                                REGION_COLORS[region] ?? "#cbd5e1";
                            return (
                                <button
                                    data-filter="region"
                                    data-value={region}
                                    class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold border-2 bg-white transition-all text-[#7A4B3A]"
                                    style={`border-color:${borderColor}`}
                                >
                                    {region}
                                </button>
                            );
                        })
                    }
                </div>
            </div>

            <!-- Precio Cards -->
            <div class="bg-[#FFFDF9] rounded-2xl p-4 border border-[#F2E8DA]">
                <h4
                    class="text-xs font-extrabold tracking-widest text-[#B58C73] uppercase mb-4"
                >
                    Precio
                </h4>
                <div class="flex gap-3" id="filter-precio">
                    <button
                        data-filter="precio"
                        data-value="gratis"
                        class="filter-btn flex-1 flex items-center justify-center gap-2 py-2.5 rounded-2xl text-sm font-semibold text-[#7A4B3A] border border-[#E8D4BE] bg-white hover:border-[#D5A77B] transition-all"
                    >
                        ✓ Gratis
                    </button>
                    <button
                        data-filter="precio"
                        data-value="pagado"
                        class="filter-btn flex-1 flex items-center justify-center gap-2 py-2.5 rounded-2xl text-sm font-semibold text-[#7A4B3A] border border-[#E8D4BE] bg-white hover:border-[#D5A77B] transition-all"
                    >
                        💳 Pagado
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @reference "../../styles/app.css";

    #filtros-panel.popup-open {
        @apply visible opacity-100 scale-100 pointer-events-auto;
    }

    /* Active states for Pill buttons */
    .filter-btn[data-filter="region"].active {
        @apply shadow-md scale-105 border-transparent text-white;
        background-color: var(--active-bg, #d5a77b);
    }
    .filter-btn[data-filter="precio"].active {
        @apply bg-[#FFF1E0] border-[#D5A77B] text-[#5A3824] shadow-inner;
    }
</style>
