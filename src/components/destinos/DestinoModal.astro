---
// DestinoModal.astro — static HTML shell; populated entirely by DestinosFilterScript
---

<div
    id="poi-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center p-4"
    aria-modal="true"
    role="dialog"
>
    <!-- Backdrop -->
    <div
        id="modal-backdrop"
        class="absolute inset-0 bg-black/40 backdrop-blur-sm"
    >
    </div>

    <!-- Panel -->
    <div
        class="modal-panel relative bg-white rounded-3xl shadow-2xl overflow-hidden w-full max-w-lg transform transition-all duration-300 scale-95 opacity-0"
    >
        <!-- Image -->
        <div class="relative h-56 overflow-hidden bg-gray-100">
            <img
                id="modal-img"
                src=""
                alt=""
                class="w-full h-full object-cover"
            />
            <button
                id="modal-close"
                class="absolute top-3 right-3 w-8 h-8 rounded-full bg-black/40 backdrop-blur-sm text-white flex items-center justify-center hover:bg-black/60 transition"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
            <div class="absolute bottom-3 left-3">
                <span
                    id="modal-price-badge"
                    class="px-3 py-1 rounded-full text-xs font-bold shadow-sm"
                ></span>
            </div>
        </div>

        <!-- Content -->
        <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
                <span id="modal-prov-dot" class="w-3 h-3 rounded-full shrink-0"
                ></span>
                <span
                    id="modal-province"
                    class="text-xs font-bold text-gray-500 uppercase tracking-wider"
                ></span>
                <span class="text-gray-300">·</span>
                <span id="modal-region" class="text-xs text-gray-400"></span>
                <span
                    id="modal-type-pill"
                    class="ml-auto inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-semibold bg-sky-50 text-sky-700"
                ></span>
            </div>

            <h2
                id="modal-name"
                class="font-heading font-bold text-2xl text-gray-800 mb-2 leading-tight"
            >
            </h2>
            <p
                id="modal-desc"
                class="text-gray-500 text-sm leading-relaxed mb-4"
            >
            </p>
            <div id="modal-tags" class="flex flex-wrap gap-1.5 mb-6"></div>

            <a
                id="modal-link"
                href="#"
                class="block w-full py-3 rounded-2xl text-center font-semibold text-white text-sm transition-all"
                style="background: linear-gradient(135deg, #0ea5e9, #14b8a6);"
            >
                Ver destino completo →
            </a>
        </div>
    </div>
</div>

<style>
    #poi-modal.open {
        display: flex;
    }
    #poi-modal.open .modal-panel {
        scale: 1;
        opacity: 1;
    }
</style>
