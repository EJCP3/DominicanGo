---
// DestinoModal.astro — static HTML shell; populated entirely by DestinosFilterScript
import Icon from '../Icon.astro';
---

<div
    id="poi-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center p-4"
    aria-modal="true"
    role="dialog"
>
    <!-- Backdrop -->
    <div
        id="modal-backdrop"
        class="absolute inset-0 bg-black/40 backdrop-blur-sm"
    >
    </div>

    <!-- Panel -->
    <div
        class="modal-panel relative bg-base-100 rounded-3xl shadow-2xl overflow-hidden w-full max-w-lg transform transition-all duration-300 scale-95 opacity-0"
    >
        <!-- Image -->
        <div class="relative h-56 overflow-hidden bg-base-300">
            <figure id="modal-gallery" class="w-full h-full m-0">
                <!-- Injected via FilterScript -->
            </figure>
            <button
                id="modal-close"
                class="absolute top-3 right-3 z-10 w-8 h-8 rounded-full bg-black/40 backdrop-blur-sm text-white flex items-center justify-center hover:bg-black/60 transition"
            >
                <Icon name="close" class="w-4 h-4" />
            </button>
            <div class="absolute bottom-3 left-3 z-10 pointer-events-none">
                <span
                    id="modal-price-badge"
                    class="px-3 py-1 rounded-full text-xs font-bold shadow-sm"
                ></span>
            </div>
        </div>

        <!-- Content -->
        <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
                <span id="modal-prov-dot" class="w-3 h-3 rounded-full shrink-0"
                ></span>
                <span
                    id="modal-province"
                    class="text-xs font-bold text-base-content/50 uppercase tracking-wider"
                ></span>
                <span class="text-base-content/30">·</span>
                <span id="modal-region" class="text-xs text-base-content/50"></span>
                <span
                    id="modal-type-pill"
                    class="ml-auto inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-semibold bg-accent/10 border border-accent/20 text-accent"
                ></span>
            </div>

            <h2
                id="modal-name"
                class="font-heading font-bold text-2xl text-base-content mb-2 leading-tight"
            >
            </h2>
            <p
                id="modal-desc"
                class="text-base-content/70 text-sm leading-relaxed mb-4"
            >
            </p>
            <div id="modal-tags" class="flex flex-wrap gap-1.5 mb-6"></div>

            <a
                id="modal-link"
                href="#"
                class="btn btn-secondary w-full rounded-2xl transition-all"
            >
                Ver destino completo →
            </a>
        </div>
    </div>
</div>

<style>
    #poi-modal.open {
        display: flex;
    }
    #poi-modal.open .modal-panel {
        scale: 1;
        opacity: 1;
    }
</style>
