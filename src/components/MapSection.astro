---
// Full-page interactive map section — light pastel theme
import Footer from "./Footer.astro";
import Icon from "./Icon.astro";
---

<section
    id="mapa"
    class="relative w-full h-screen pt-14 flex flex-col"
    style="background: linear-gradient(180deg, #e8f4f8 0%, #d4eef7 30%, #e2f0e8 60%, #eef6fa 100%);"
>
    <div
        class="flex-1 relative max-w-[1400px] w-full mx-auto px-4 sm:px-6 flex flex-col"
    >
        <!-- Map container -->
        <div class="flex-1 relative" id="map-wrapper">
            <div class="map-container w-full h-full" id="map-container">
                <!-- Province tooltip -->
                <div
                    id="province-tooltip"
                    class="fixed pointer-events-none z-50 opacity-0 transition-opacity duration-200 px-4 py-2 rounded-xl bg-base-100/95 backdrop-blur-md border border-base-200 shadow-lg text-sm font-heading font-semibold text-base-content"
                >
                    <span id="tooltip-text"></span>
                </div>

                <!-- SVG Map -->
                <svg
                    viewBox="0 0 960 500"
                    class="w-full h-full"
                    id="rd-map"
                    xmlns="http://www.w3.org/2000/svg"
                    preserveAspectRatio="xMidYMid meet"
                >
                    <!-- Loading indicator -->
                    <text
                        id="map-loading"
                        x="480"
                        y="250"
                        class="text-[14px] font-heading pointer-events-none"
                        fill="#94a3b8"
                        text-anchor="middle">Cargando mapa...</text
                    >

                    <!-- Water labels -->
                    <text
                        x="620"
                        y="50"
                        class="text-[11px] italic font-body pointer-events-none tracking-[0.3em] uppercase"
                        fill="#a3c9d9"
                        text-anchor="middle">Océano Atlántico</text
                    >
                    <text
                        x="400"
                        y="470"
                        class="text-[11px] italic font-body pointer-events-none tracking-[0.3em] uppercase"
                        fill="#a3c9d9"
                        text-anchor="middle">Mar Caribe</text
                    >

                    <!-- Province paths rendered from GeoJSON -->
                    <g id="provinces-group"></g>
                    <!-- Province labels rendered by JS -->
                    <g id="labels-group"></g>

                    <!-- Extra overlays injected by JS (water bodies, islands, etc.) -->
                    <g id="overlays-group"></g>

                    <!-- Compass icon -->
                    <g
                        transform="translate(830, 400)"
                        class="pointer-events-none"
                    >
                        <g id="map-compass">
                            <circle
                                cx="0"
                                cy="0"
                                r="18"
                                fill="none"
                                stroke="#b8ccd6"
                                stroke-width="1"></circle>
                            <circle cx="0" cy="0" r="2" fill="#b8ccd6"></circle>
                            <line
                                x1="0"
                                y1="-14"
                                x2="0"
                                y2="-6"
                                stroke="#b8ccd6"
                                stroke-width="1.5"></line>
                            <line
                                x1="0"
                                y1="6"
                                x2="0"
                                y2="14"
                                stroke="#b8ccd6"
                                stroke-width="1"></line>
                            <line
                                x1="-14"
                                y1="0"
                                x2="-6"
                                y2="0"
                                stroke="#b8ccd6"
                                stroke-width="1"></line>
                            <line
                                x1="6"
                                y1="0"
                                x2="14"
                                y2="0"
                                stroke="#b8ccd6"
                                stroke-width="1"></line>
                            <polygon points="0,-14 -3,-8 3,-8" fill="#b8ccd6"
                            ></polygon>
                        </g>
                    </g>
                </svg>
            </div>
        </div>

        <!-- Bottom hint bar -->
        <div
            id="hint-bar"
            class="flex items-center justify-center pb-28 md:pb-4 pt-2 relative z-10"
        >
            <div
                class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-base-100/90 backdrop-blur-sm border border-base-200 shadow-sm text-sm text-base-content/70 transition-all"
            >
                <span class="w-2 h-2 rounded-full bg-info animate-pulse"></span>

                <span
                    class="overflow-hidden h-5 inline-flex flex-col relative font-medium text-rotate animate-text-slide duration-15000"
                >
                    <span class="animate-text-slide flex flex-col items-start">
                        <span class="h-5 flex items-center"
                            >Haz clic en una provincia</span
                        >
                        <span class="h-5 flex items-center"
                            >Descubre lugares únicos</span
                        >
                        <span class="h-5 flex items-center"
                            >Planifica tu aventura</span
                        >
                        <span class="h-5 flex items-center"
                            >Encuentra tu destino</span
                        >
                        <span class="h-5 flex items-center"
                            >Explora el paraíso</span
                        >
                    </span>
                </span>
            </div>
        </div>
    </div>

    <Footer />
</section>
