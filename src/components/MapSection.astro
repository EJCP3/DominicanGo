---
// Full-page interactive map section — light pastel theme
---

<section
    id="mapa"
    class="relative w-full h-screen pt-14 flex flex-col"
    style="background: linear-gradient(180deg, #e8f4f8 0%, #d4eef7 30%, #e2f0e8 60%, #eef6fa 100%);"
>
    <div
        class="flex-1 relative max-w-[1400px] w-full mx-auto px-4 sm:px-6 flex flex-col"
    >
        <!-- Map container -->
        <div class="flex-1 relative" id="map-wrapper">
            <div class="map-container w-full h-full" id="map-container">
                <!-- Province tooltip -->
                <div
                    id="province-tooltip"
                    class="fixed pointer-events-none z-50 opacity-0 transition-opacity duration-200 px-4 py-2 rounded-xl bg-white/95 backdrop-blur-md border border-gray-200 shadow-lg text-sm font-heading font-semibold text-gray-700"
                >
                    <span id="tooltip-text"></span>
                </div>

                <!-- SVG Map -->
                <svg
                    viewBox="0 0 960 500"
                    class="w-full h-full"
                    id="rd-map"
                    xmlns="http://www.w3.org/2000/svg"
                    preserveAspectRatio="xMidYMid meet"
                >
                    <!-- Loading indicator -->
                    <text
                        id="map-loading"
                        x="480"
                        y="250"
                        class="text-[14px] font-heading pointer-events-none"
                        fill="#94a3b8"
                        text-anchor="middle">Cargando mapa...</text
                    >

                    <!-- Water labels -->
                    <text
                        x="620"
                        y="50"
                        class="text-[11px] italic font-body pointer-events-none tracking-[0.3em] uppercase"
                        fill="#a3c9d9"
                        text-anchor="middle">Océano Atlántico</text
                    >
                    <text
                        x="400"
                        y="470"
                        class="text-[11px] italic font-body pointer-events-none tracking-[0.3em] uppercase"
                        fill="#a3c9d9"
                        text-anchor="middle">Mar Caribe</text
                    >

                    <!-- Province paths rendered from GeoJSON -->
                    <g id="provinces-group"></g>
                    <!-- Province labels rendered by JS -->
                    <g id="labels-group"></g>

                    <!-- Extra overlays injected by JS (water bodies, islands, etc.) -->
                    <g id="overlays-group"></g>

                    <!-- Compass icon -->
                    <g
                        transform="translate(830, 400)"
                        class="pointer-events-none"
                    >
                        <circle
                            cx="0"
                            cy="0"
                            r="18"
                            fill="none"
                            stroke="#b8ccd6"
                            stroke-width="1"></circle>
                        <circle cx="0" cy="0" r="2" fill="#b8ccd6"></circle>
                        <line
                            x1="0"
                            y1="-14"
                            x2="0"
                            y2="-6"
                            stroke="#b8ccd6"
                            stroke-width="1.5"></line>
                        <line
                            x1="0"
                            y1="6"
                            x2="0"
                            y2="14"
                            stroke="#b8ccd6"
                            stroke-width="1"></line>
                        <line
                            x1="-14"
                            y1="0"
                            x2="-6"
                            y2="0"
                            stroke="#b8ccd6"
                            stroke-width="1"></line>
                        <line
                            x1="6"
                            y1="0"
                            x2="14"
                            y2="0"
                            stroke="#b8ccd6"
                            stroke-width="1"></line>
                        <polygon points="0,-14 -3,-8 3,-8" fill="#b8ccd6"
                        ></polygon>
                    </g>
                </svg>
            </div>
        </div>

        <!-- Bottom hint bar -->
        <div class="flex items-center justify-center pb-4 pt-2">
            <div
                class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-white/90 backdrop-blur-sm border border-gray-200 shadow-sm text-sm text-gray-500"
            >
                <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse"
                ></span>
                Haz clic en una provincia para explorar
            </div>
        </div>
    </div>

    <!-- Footer info -->
    <div
        class="px-6 pb-3 flex items-center justify-between text-[10px] text-gray-400 tracking-widest uppercase max-w-[1400px] w-full mx-auto"
    >
        <span class="flex items-center gap-2">
            <svg
                class="w-3 h-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
                ></path>
            </svg>
            Mapa Interactivo • República Dominicana
        </span>
        <span>&copy; 2026 DominicanGo</span>
    </div>
</section>
