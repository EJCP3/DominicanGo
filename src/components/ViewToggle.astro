---
// src/components/ViewToggle.astro
const currentPath = Astro.url.pathname;
const isMapActive = currentPath === '/' || currentPath === '/index';
const isGridActive = currentPath.startsWith('/destinos');

// Opcional: Solo mostrar el toggle en las rutas principales (Mapa o Grid)
const showToggle = currentPath === '/' || currentPath === '/index' || currentPath.startsWith('/destinos');
---

{showToggle && (
<div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-100 bg-base-100/90 backdrop-blur-md p-1.5 rounded-full shadow-xl border border-base-200 flex items-center transition-all hover:shadow-2xl">
    
    <!-- Botón Mapa -->
    <a 
        href="/" 
        class={`flex items-center justify-center gap-2 px-6 py-2.5 rounded-full text-sm font-bold transition-all duration-300 ${
            isMapActive 
            ? 'bg-primary text-primary-content shadow-md scale-100' 
            : 'text-base-content/70 hover:text-base-content hover:bg-base-200/50 hover:scale-105'
        }`}
        aria-label="Vista de Mapa"
    >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        Mapa
    </a>
    
    <!-- Separador sutil -->
    {!isMapActive && !isGridActive ? <div class="w-px h-6 bg-base-300 mx-1"></div> : null}

    <!-- Botón Grid (Destinos) -->
    <a 
        href="/destinos" 
        class={`flex items-center justify-center gap-2 px-6 py-2.5 rounded-full text-sm font-bold transition-all duration-300 ${
            isGridActive 
            ? 'bg-primary text-primary-content shadow-md scale-100' 
            : 'text-base-content/70 hover:text-base-content hover:bg-base-200/50 hover:scale-105'
        }`}
        aria-label="Vista de Cuadrícula"
    >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
        Grid
    </a>

</div>
)}
