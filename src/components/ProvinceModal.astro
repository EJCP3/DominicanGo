---
// Province detail modal — light glassmorphism theme
---

<div
    id="modal-overlay"
    class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6"
>
    <!-- Backdrop -->
    <div
        id="modal-backdrop"
        class="absolute inset-0 bg-black/20 backdrop-blur-sm modal-overlay"
        onclick="closeModal()"
    >
    </div>

    <!-- Modal Panel -->
    <div
        id="modal-panel"
        class="relative modal-panel w-full max-w-2xl max-h-[85vh] rounded-3xl overflow-hidden shadow-2xl"
        style="background: rgba(255, 255, 255, 0.92); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.8); box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15);"
    >
        <!-- Modal Header -->
        <div
            class="p-6 pb-4 border-b border-gray-100 flex items-start justify-between"
        >
            <div>
                <div class="flex items-center gap-2 mb-1">
                    <div class="w-3 h-3 rounded-full" id="modal-color-dot">
                    </div>
                    <span
                        class="text-xs text-gray-400 uppercase tracking-wider font-medium"
                        >Provincia</span
                    >
                </div>
                <h4
                    class="font-heading font-bold text-2xl sm:text-3xl text-gray-800"
                    id="modal-title"
                >
                </h4>
                <p
                    class="text-gray-500 text-sm mt-1 leading-relaxed"
                    id="modal-description"
                >
                </p>
            </div>
            <button
                onclick="closeModal()"
                class="flex-shrink-0 ml-4 w-10 h-10 rounded-xl bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors text-gray-400 hover:text-gray-600"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- Modal Body -->
        <div
            class="p-6 overflow-y-auto custom-scrollbar"
            style="max-height: calc(85vh - 120px);"
        >
            <div
                class="text-xs text-gray-400 uppercase tracking-wider font-medium mb-4"
            >
                Puntos de Interés
            </div>
            <div class="space-y-4" id="modal-pois">
                <!-- POI cards injected by JS -->
            </div>
        </div>
    </div>
</div>
