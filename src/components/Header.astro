---
// Header — light theme with clean nav
const currentPath = Astro.url.pathname;
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 no-underline
"
>
    <div
        class="max-w-[1400px] mx-auto px-6 py-3 flex items-center justify-between"
    >
        <!-- Logo -->
        <div class="flex items-center gap-2">
          
            <a
                href="/"
                class="no-underline
 font-heading font-bold text-gray-800 text-lg hover:text-gray-600 transition-colors"
            >
                DominicanGo <span class="font-light text-gray-400"></span>
            </a>
        </div>

        <!-- Nav links -->
        <nav class="hidden md:flex items-center gap-1">
            <a
                href="/"
                class={`no-underline
 px-4 py-1.5 rounded-full text-sm font-medium transition-all ${
                    currentPath === "/"
                        ? "text-gray-800 bg-gray-100"
                        : "text-gray-500 hover:text-gray-800 hover:bg-gray-100"
                }`}
            >
                Mapa
            </a>
            <a
                href="/destinos"
                class={`no-underline
 px-4 py-1.5 rounded-full text-sm font-medium transition-all ${
                    currentPath.startsWith("/destinos")
                        ? "text-gray-800 bg-gray-100"
                        : "text-gray-500 hover:text-gray-800 hover:bg-gray-100"
                }`}
            >
                Destinos
            </a>
            <a
                href="#"
                class="no-underline
 px-4 py-1.5 rounded-full text-sm font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100 transition-all"
            >
                Blog
            </a>
        </nav>

        <!-- Search icon -->
        <button
            class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-400 hover:text-gray-600 hover:border-gray-300 transition-colors"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
        </button>
    </div>
</header>
