---
// Header — auth-aware with Bearer token login/user dropdown
import ThemeDropdown from "./header/ThemeDropdown.astro";
import MobileMenu from "./header/MobileMenu.astro";
import ThemeScript from "./header/ThemeScript.astro";
import { getUser } from "../services/api";

const currentPath = Astro.url.pathname;
const isHomeOrDestinos = currentPath === "/" || currentPath.startsWith("/destinos");

// Read JWT from cookie and validate with backend
const token = Astro.cookies.get("auth_token")?.value;
const user = await getUser(token);

const API_BASE = import.meta.env.PUBLIC_API_URL?.replace('/api', '') || 'http://localhost:3000';
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md no-underline">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
        <!-- Logo -->
        <div class="flex items-center gap-2">
            <a
                href="/"
                class="no-underline font-heading font-extrabold text-neutral text-lg sm:text-xl transition-all hover:opacity-80"
            >
                Dominican<span class="text-success font-extrabold text-2xl">Go</span>
            </a>
        </div>

        <!-- Nav links (Desktop) -->
        <nav class="hidden md:flex items-center gap-1">
            <a
                href="/"
                class={`no-underline px-4 py-1.5 rounded-full text-sm font-medium transition-all ${
                    isHomeOrDestinos
                        ? "text-base-content bg-base-200"
                        : "text-base-content/70 hover:text-base-content hover:bg-base-200"
                }`}
            >
                Destinos
            </a>
            <a
                href="/blog"
                class={`no-underline px-4 py-1.5 rounded-full text-sm font-medium transition-all ${
                    currentPath.startsWith("/blog")
                        ? "text-base-content bg-base-200"
                        : "text-base-content/70 hover:text-base-content hover:bg-base-200"
                }`}
            >
                Blog
            </a>
            </a>
            {user && (
                <a
                    href="/favoritos"
                    class={`no-underline px-4 py-1.5 rounded-full text-sm font-medium transition-all ${
                        currentPath.startsWith("/favoritos")
                            ? "text-base-content bg-base-200"
                            : "text-base-content/70 hover:text-base-content hover:bg-base-200"
                    }`}
                >
                    Favoritos
                </a>
            )}
        </nav>

        <!-- Right Side Actions -->
        <div class="flex items-center gap-2 sm:gap-3">
            {user ? (
                <>
                    <a href="/nuevo-destino" class="btn btn-secondary btn-sm rounded-full hidden md:inline-flex shadow-sm">
                        Registrar Destino
                    </a>

                    <!-- DaisyUI Avatar Dropdown -->
                    <div class="dropdown dropdown-end">
                        <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
                            <div class="w-9 rounded-full ring ring-primary ring-offset-base-100 ring-offset-1">
                                {user.foto
                                    ? <img alt={user.name} src={user.foto} referrerpolicy="no-referrer" />
                                    : <div class="bg-primary text-primary-content flex items-center justify-center w-full h-full text-sm font-bold rounded-full select-none">{user.name?.charAt(0).toUpperCase()}</div>
                                }
                            </div>
                        </div>
                        <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-100 p-2 shadow-xl bg-base-100 rounded-2xl w-56 border border-base-200">
                            <li class="menu-title px-2 py-1">
                                <span class="font-semibold text-sm text-base-content truncate">{user.name}</span>
                                <span class="text-xs text-base-content/50 font-normal truncate">{user.email}</span>
                            </li>
                            <div class="divider my-0.5"></div>
                            <li><a href="/favoritos">❤️ Mis Favoritos</a></li>
                            <li><a href="/nuevo-destino">➕ Registrar Destino</a></li>
                            <div class="divider my-0.5"></div>
                            <li>
                                <a href="/logout" class="text-error font-medium">🚪 Cerrar sesión</a>
                            </li>
                        </ul>
                    </div>
                </>
            ) : (
                /* Logged out: Google Sign-In button */
                <a
                    href={`${API_BASE}/auth/google`}
                    class="btn btn-primary btn-sm rounded-full shadow-sm gap-2"
                >
                    <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Iniciar sesión
                </a>
            )}

            <ThemeDropdown />
            <MobileMenu />
        </div>
    </div>
</header>
<ThemeScript />
