---
const categories = [
    "Aventura",
    "Cultura",
    "Naturaleza",
    "Experiencia",
    "Gastronomía",
    "Relajación",
    "Romance",
    "Fotografía",
    "Otro",
];

// Aesthetic solid colors for category tags when active
const CATEGORY_COLORS: Record<string, string> = {
    Aventura: "#f59e0b", // amber
    Cultura: "#8b5cf6", // purple
    Naturaleza: "#22c55e", // green
    Experiencia: "#eab308", // yellow
    Gastronomía: "#ef4444", // red
    Relajación: "#0ea5e9", // light blue
    Romance: "#db2777", // pink
    Fotografía: "#64748b", // slate
    Otro: "#94a3b8",
};

const currentCategory = Astro.url.searchParams.get("category") || "todas";
---

<div
    id="blog-filtros-panel"
    class="invisible opacity-0 scale-95 pointer-events-none origin-left transition-all duration-300 ease-out absolute top-30 left-0 -translate-y-1/2 w-[calc(100vw-2rem)] sm:w-[550px] z-50 bg-[#FCFBF9] border border-[#F2E8DC] shadow-2xl rounded-3xl p-6"
>
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-extrabold text-[#2F3D4E]">Filtros</h3>
        <div class="flex items-center gap-1">
            <a
                id="reset-blog-filters"
                href="/blog"
                class="btn btn-sm btn-circle btn-ghost text-slate-400 hover:text-slate-700 transition-colors inline-flex items-center justify-center flex-col shrink-0"
                title="Limpiar filtros"
            >
                <svg
                    class="w-4 h-4 text-current"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                    ></path></svg
                >
            </a>
            <button
                class="btn btn-sm btn-circle btn-ghost text-slate-400 hover:text-slate-700 transition-colors"
                onclick="document.getElementById('blog-filtros-panel').classList.remove('popup-open');"
            >
                <svg
                    class="w-4 h-4 text-current"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M6 18L18 6M6 6l12 12"></path></svg
                >
            </button>
        </div>
    </div>

    <!-- Body Layout -->
    <div class="space-y-4">
        <!-- Categories Cards (Transparent w/ borders) -->
        <div
            class="bg-transparent rounded-2xl p-4 md:p-5 border border-[#F2E8DC]"
        >
            <h4
                class="text-[11px] font-extrabold tracking-widest text-[#BA9A84] uppercase mb-4"
            >
                Categorías
            </h4>
            <div class="flex flex-wrap gap-2.5" id="blog-filter-category">
                <a
                    data-filter="category"
                    data-value="todas"
                    href="/blog"
                    class={`filter-btn category-btn inline-block text-center px-4 py-1.5 rounded-full text-[13px] font-bold border-[1.5px] border-[#DEE3EC] bg-white transition-all text-[#664634] ${currentCategory === "todas" ? "active" : "hover:bg-base-200"}`}
                    style="--active-border:#3b82f6"
                >
                    Todas las historias
                </a>
                {
                    categories.map((cat: string) => {
                        const activeColor = CATEGORY_COLORS[cat] ?? "#cbd5e1"; // Fallback
                        return (
                            <a
                                data-filter="category"
                                data-value={cat}
                                href={`/blog?category=${encodeURIComponent(cat)}`}
                                class={`filter-btn category-btn inline-block text-center px-4 py-1.5 rounded-full text-[13px] font-bold border-[1.5px] border-[#DEE3EC] bg-white transition-all text-[#664634] ${currentCategory === cat ? "active" : "hover:bg-base-200"}`}
                                style={`--active-border:${activeColor}`}
                            >
                                {cat}
                            </a>
                        );
                    })
                }
            </div>
        </div>
    </div>
</div>

<style>
    @reference "../../styles/app.css";

    #blog-filtros-panel.popup-open {
        @apply visible opacity-100 scale-100 pointer-events-auto;
    }

    /* Active states for Pill buttons based on Figma */
    .filter-btn.category-btn.active {
        border-color: var(--active-border, #0ea5e9);
        @apply shadow-sm scale-105;
        box-shadow: 0 2px 8px -2px var(--active-border, #0ea5e9) 33; /* Soft glow of the color */
    }
</style>

<script>
    // Visual toggling only for prototype
    document.addEventListener("astro:page-load", () => {
        // Removed JS-based window redirection logic, it is now seamlessly handled by Astro anchors.

        // Close panel when clicking outside
        // Add only once using an IIFE module scope logic OR just a simple check, but Astro scripts run once.
        document.addEventListener("click", (event) => {
            const currentPanel = document.getElementById("blog-filtros-panel");
            const currentBtn = document.getElementById("btn-abrir-filtros");
            if (!currentPanel) return;

            const target = event.target as Node;
            const isInsidePanel = currentPanel.contains(target);
            const isClickOnBtn = currentBtn
                ? currentBtn.contains(target)
                : false;

            if (
                !isInsidePanel &&
                !isClickOnBtn &&
                currentPanel.classList.contains("popup-open")
            ) {
                currentPanel.classList.remove("popup-open");
            }
        });
    });
</script>
