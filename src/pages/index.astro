---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import MapSection from "../components/MapSection.astro";
import ProvinceModal from "../components/ProvinceModal.astro";
import { provinces } from "../data/provinces.js";
---

<Layout>
	<Header />
	<MapSection />
	<ProvinceModal />

	<!-- Province data for JS -->
	<script define:vars={{ provinces }}>
		window.__PROVINCES__ = provinces;
	</script>

	<!-- App entry point -->
	<script>
		import "../scripts/app.js";
	</script>
</Layout>
