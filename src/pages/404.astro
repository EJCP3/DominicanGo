---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { Icon } from "astro-icon/components";
---

<Layout
  title="404 — Destino No Encontrado"
  description="La página que buscas no existe."
  showWidgets={false}
>
  <Header />
  <div class="page-wrapper bg-base-100">
    <!-- ═══════════════════════════════════ DECORATIONS ═══════ -->
    <!-- Clouds top -->
    <div class="deco deco-clouds">
      <img
        src="/undraw_clouds_bmtk.svg"
        alt=""
        aria-hidden="true"
        loading="eager"
      />
    </div>

    <!-- Polaroid top-left -->
    <div class="deco deco-polaroid">
      <img
        src="/undraw_polaroid_qqdz.svg"
        alt=""
        aria-hidden="true"
        loading="eager"
      />
    </div>

    <!-- Beach bottom-right -->
    <div class="deco deco-beach">
      <img
        src="/undraw_beach-day_cnsv.svg"
        alt=""
        aria-hidden="true"
        loading="eager"
      />
    </div>

    <!-- On-the-way bottom-left -->
    <div class="deco deco-onway">
      <img
        src="/undraw_on-the-way_zwi3.svg"
        alt=""
        aria-hidden="true"
        loading="eager"
      />
    </div>

    <!-- ═══════════════════════════════════ MAIN CONTENT ═══════ -->
    <main
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center justify-between px-6 py-20 lg:py-28 relative z-10 w-full min-h-[calc(100vh-8rem)]"
      role="main"
      aria-labelledby="page-title"
    >
      <!-- Left side: Text & Actions -->
      <div
        class="w-full lg:w-1/2 flex flex-col items-center lg:items-start text-center lg:text-left gap-6 order-2 lg:order-1 mt-12 lg:mt-0"
      >
        <!-- Tags row -->
        <div
          class="flex flex-wrap justify-center lg:justify-start gap-3 fade-up delay-1"
        >
          <span
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest border border-error/20 bg-error/10 text-error"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
              ></path></svg
            >
            Coordenada inexistente
          </span>
          <span
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest border border-primary/20 bg-primary/10 text-primary"
          >
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"
              ></path></svg
            >
            Exploración activa
          </span>
        </div>

        <!-- Headline -->
        <h1
          id="page-title"
          class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold italic fade-up delay-2 text-primary tracking-tighter"
        >
          ¡Te has perdido, explorador!
        </h1>

        <!-- Sub-text -->
        <p
          class="text-base sm:text-lg leading-relaxed fade-up delay-3 text-base-content/70 max-w-[46ch] font-medium"
        >
          Parece que esta ruta no está en nuestro mapa de aventuras. La página
          que buscas fue arrastrada por la marea o todavía no ha sido
          cartografiada por nuestra expedición.
        </p>

      

        <!-- CTA buttons -->
        <div
          class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start fade-up delay-5 w-full"
        >
          <a
            href="/"
            class="btn btn-primary rounded-2xl px-8 shadow-lg shadow-primary/30 flex items-center gap-2 hover:-translate-y-1 transition-transform"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
              ></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg
            >
            Volver al Mapa Principal
          </a>
          <button
            onclick="history.back()"
            class="btn btn-outline border-base-content/20 text-base-content/70 hover:bg-base-200 hover:border-primary hover:text-primary rounded-2xl px-6 flex items-center gap-2"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M19 12H5"></path><path d="m12 19-7-7 7-7"></path></svg
            >
            Retroceder
          </button>

          <a
            href="/destinos"
            class="btn btn-outline border-base-content/20 text-base-content/70 hover:bg-base-200 hover:border-primary hover:text-primary rounded-2xl px-6 flex items-center gap-2"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
              ></path></svg
            >
            Ver Destinos
          </a>
        </div>
      </div>

      <!-- Right side: Huge 404 + Animated Compass -->
      <div
        class="w-full lg:w-1/2 flex items-center justify-center relative fade-up delay-3 order-1 lg:order-2 h-64 lg:h-auto"
      >
        <!-- 404 Background text -->
        <div
          class="absolute inset-0 flex items-center justify-center z-0 pointer-events-none select-none"
        >
          <span
            class="text-[12rem] md:text-[18rem] lg:text-[22rem] font-black leading-none text-base-content/5 tracking-tighter mix-blend-multiply"
          >
            404
          </span>
        </div>

        <!-- Compass SVG -->
        <div class="relative z-10 drop-shadow-2xl">
          <svg
            class="w-48 h-48 md:w-64 md:h-64 lg:w-80 lg:h-80 text-primary"
            viewBox="0 0 100 100"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <!-- Outer Ring -->
            <circle
              cx="50"
              cy="50"
              r="46"
              stroke="currentColor"
              stroke-width="3"
              fill="oklch(var(--b1) / 0.8)"
              class="backdrop-blur-sm"></circle>
            <circle
              cx="50"
              cy="50"
              r="40"
              stroke="currentColor"
              stroke-width="1"
              stroke-dasharray="2 3"
              opacity="0.6"></circle>

            <!-- N, S, E, W -->
            <text
              x="50"
              y="15"
              text-anchor="middle"
              font-family="'Courier New', monospace"
              font-size="8"
              font-weight="bold"
              fill="currentColor">N</text
            >
            <text
              x="50"
              y="91"
              text-anchor="middle"
              font-family="'Courier New', monospace"
              font-size="8"
              font-weight="bold"
              fill="currentColor">S</text
            >
            <text
              x="14"
              y="53"
              text-anchor="middle"
              font-family="'Courier New', monospace"
              font-size="8"
              font-weight="bold"
              fill="currentColor">W</text
            >
            <text
              x="86"
              y="53"
              text-anchor="middle"
              font-family="'Courier New', monospace"
              font-size="8"
              font-weight="bold"
              fill="currentColor">E</text
            >

            <!-- Compass Needle -->
            <g class="compass-needle-spin" style="transform-origin: 50% 50%;">
              <!-- Red (North) Needle -->
              <path d="M 45 50 L 50 20 L 55 50 Z" fill="oklch(var(--er))"
              ></path>
              <path d="M 45 50 L 50 20 L 50 50 Z" fill="oklch(var(--er) / 0.8)"
              ></path>

              <!-- Gray (South) Needle -->
              <path
                d="M 45 50 L 50 80 L 55 50 Z"
                fill="currentColor"
                opacity="0.3"></path>
              <path
                d="M 45 50 L 50 80 L 50 50 Z"
                fill="currentColor"
                opacity="0.5"></path>

              <!-- Center Pin -->
              <circle cx="50" cy="50" r="6" fill="currentColor"></circle>
              <circle cx="50" cy="50" r="2" fill="oklch(var(--b1))"></circle>
            </g>
          </svg>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  /* ─── Page layout ─── */
  .page-wrapper {
    display: grid;
    position: relative;
    isolation: isolate;
    background-image:
      radial-gradient(
        ellipse 80% 60% at 50% 0%,
        oklch(var(--p) / 0.06) 0%,
        transparent 70%
      ),
      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d4a832' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    overflow: hidden;
  }

  /* ─── Number 404 ─── */
  .giant-404 {
    font-size: clamp(6rem, 20vw, 15rem);
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(
      135deg,
      oklch(var(--p)) 0%,
      oklch(var(--a)) 50%,
      oklch(var(--s)) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.05em;
    user-select: none;
    position: relative;
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
  }

  .giant-404::after {
    content: "404";
    position: absolute;
    inset: 0;
    background: none;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 1px oklch(var(--p) / 0.15);
    transform: translate(6px, 8px);
    z-index: -1;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
  }

  /* ─── Card ─── */

  /* ─── Divider stamp ─── */
  .stamp-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: oklch(var(--bc) / 0.6);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .stamp-divider::before,
  .stamp-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(var(--bc) / 0.2),
      transparent
    );
  }

  /* ─── Floating SVG decorations ─── */
  .deco {
    position: absolute;
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  .deco-clouds {
    top: 10%;
    left: 0;
    width: min(700px, 95vw);
    opacity: 0.4;
    animation: cloudDrift 65s ease-in-out infinite alternate;
  }

  .deco-beach {
    bottom: -5%;
    right: -10%;
    width: min(380px, 45vw);
    opacity: 0.6;
    animation: floatY 7s ease-in-out infinite reverse;
    transform-origin: bottom right;
  }

  .deco-polaroid {
    top: 15%;
    left: -5%;
    width: min(220px, 30vw);
    opacity: 0.55;
    animation: floatTilt 9s ease-in-out infinite;
    transform: rotate(-8deg);
  }

  .deco-onway {
    bottom: 0;
    left: 0;
    width: min(200px, 28vw);
    opacity: 0.5;
    animation: scooterDrift 130s linear infinite;
  }

  @keyframes floatY {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-16px) rotate(0deg);
    }
  }
  @keyframes cloudDrift {
    0% {
      transform: translate(-60%, 0);
    }
    100% {
      transform: translate(calc(100vw - 40%), -15px);
    }
  }
  @keyframes scooterDrift {
    0% {
      transform: translate(-60%, 0) scaleX(1);
      animation-timing-function: ease-in-out;
    }
    49.9% {
      transform: translate(calc(100vw - 40%), 0) scaleX(1);
      animation-timing-function: step-end;
    }
    50% {
      transform: translate(calc(100vw - 40%), 0) scaleX(-1);
      animation-timing-function: ease-in-out;
    }
    99.9% {
      transform: translate(-60%, 0) scaleX(-1);
      animation-timing-function: step-end;
    }
    100% {
      transform: translate(-60%, 0) scaleX(1);
    }
  }
  @keyframes floatTilt {
    0%,
    100% {
      transform: rotate(-8deg) translateY(0px);
    }
    50% {
      transform: rotate(-5deg) translateY(-12px);
    }
  }

  /* ─── Main illustration ─── */
  .main-illo {
    width: min(380px, 90vw);
    animation: floatY 6s ease-in-out infinite 0.5s;
  }

  /* ─── Compass spinner ─── */
  .compass-spin {
    width: 2.25rem;
    height: 2.25rem;
    animation: compassSpin 4s linear infinite;
  }
  @keyframes compassSpin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  /* ─── Giant Compass Needle ─── */
  .compass-needle-spin {
    animation: spinNeedle 4s ease-in-out infinite;
  }
  @keyframes spinNeedle {
    0% {
      transform: rotate(0deg);
    }
    10% {
      transform: rotate(15deg);
    }
    30% {
      transform: rotate(-5deg);
    }
    50% {
      transform: rotate(180deg);
    }
    70% {
      transform: rotate(160deg);
    }
    90% {
      transform: rotate(365deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  /* ─── Fade-in entrance ─── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .fade-up {
    animation: fadeUp 0.7s ease both;
  }
  .delay-1 {
    animation-delay: 0.1s;
  }
  .delay-2 {
    animation-delay: 0.22s;
  }
  .delay-3 {
    animation-delay: 0.36s;
  }
  .delay-4 {
    animation-delay: 0.5s;
  }
  .delay-5 {
    animation-delay: 0.65s;
  }

  /* ─── Footer links ─── */
  .footer-link {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: oklch(var(--bc) / 0.6);
    text-decoration: none;
    transition: color 0.2s;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
  }
  .footer-link:hover {
    color: oklch(var(--p));
    border-bottom-color: oklch(var(--p) / 0.5);
  }

  /* ─── Responsive tweaks ─── */
  @media (max-width: 640px) {
    .deco-beach {
      display: none;
    }
    .deco-polaroid {
      display: none;
    }
  }
</style>
