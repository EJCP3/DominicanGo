---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/layout/Header.astro";
import { getProvincesWithDestinations, slugify, getFavoriteIds, getUser } from "../../../services/api";
import { DEFAULT_HOURS } from "../../../data/poi-config.ts";
import PoiHero from "../../../components/poi/PoiHero.astro";
import PoiBentoGrid from "../../../components/poi/PoiBentoGrid.astro";
import PoiSidebar from "../../../components/poi/PoiSidebar.astro";
import PoiRelated from "../../../components/poi/PoiRelated.astro";
import SocialActions from "../../../components/interactions/SocialActions.vue";
import Comments from "../../../components/interactions/Comments.vue";

const token = Astro.cookies.get("auth_token")?.value ?? "";
const isLoggedIn = !!token;
const API_BASE = import.meta.env.PUBLIC_API_URL?.replace('/api', '') || 'http://localhost:3000';
const loginUrl = `${API_BASE}/auth/google`;

// Parallelize API calls
const [{ provinces }, { destinationIds: favDestinationIds }, user] = await Promise.all([
    getProvincesWithDestinations(),
    getFavoriteIds(token),
    getUser(token)
]);

const { province: slugProvince, poi: slugPoi } = Astro.params;
const provinceSlug = slugProvince as string;

const province = (provinces as any)[provinceSlug];
if (!province) {
    return Astro.redirect("/destinos");
}

const poi = province.pois.find(
    (p: any) => p.name && slugify(p.name) === slugPoi,
);
if (!poi) {
    return Astro.redirect("/destinos");
}

// Related: same type OR same province, max 6
let related = Object.entries(provinces)
    .flatMap(([slug, prov]) =>
        (prov as any).pois
            .filter(
                (p: any) =>
                    p.name !== poi.name &&
                    (p.type?.toLowerCase() === poi.type?.toLowerCase() || slug === provinceSlug),
            )
            .map((p: any) => ({
                ...p,
                type: p.type?.toLowerCase(),
                province: (prov as any).name,
                provinceSlug: slug,
                provinceColor: (prov as any).color,
                region: (prov as any).region,
                href: `/destinos/${slug}/${slugify(p.name)}`,
            }))
    );

// Fallback: if no direct matches found, just take some other destinations
if (related.length === 0) {
    related = Object.entries(provinces)
        .flatMap(([slug, prov]) =>
            (prov as any).pois
                .filter((p: any) => p.name !== poi.name)
                .map((p: any) => ({
                    ...p,
                    type: p.type?.toLowerCase(),
                    province: (prov as any).name,
                    provinceSlug: slug,
                    provinceColor: (prov as any).color,
                    region: (prov as any).region,
                    href: `/destinos/${slug}/${slugify(p.name)}`,
                }))
        );
}

related = related.slice(0, 6);

// Bento images
const seed = slugify(poi.name);
const bentoImages: string[] = poi.images?.length
    ? poi.images
    : [
          `https://picsum.photos/seed/${seed}-b/600/400`,
          `https://picsum.photos/seed/${seed}-c/600/400`,
          `https://picsum.photos/seed/${seed}-d/600/400`,
      ];

// Hours + website
const hours = poi.hours ??
    DEFAULT_HOURS[poi.type] ?? {
        weekdays: "Consultar disponibilidad",
        weekend: "",
    };
const website = poi.website ?? null;
const mapLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${poi.name}, ${province.name}, República Dominicana`)}`;
const showHours = poi.type !== "playa";

const isFavorited = poi.id ? favDestinationIds.has(poi.id) : false;
---

<Layout title={`${poi.name} — DominicanGo`} description={poi.description}>
    <Header />

    <main>
    <article>
        <PoiHero
            name={poi.name}
            slug={`${provinceSlug}-${seed}`}
            type={poi.type}
            province={province.name}
            description={poi.description}
            price={poi.price}
            hours={hours}
            website={website}
            image={poi.image || bentoImages[0]}
            images={bentoImages}
            color={province.color}
            provinceSlug={provinceSlug}
            poiSlug={seed}
        />

        <div class="bg-base-300">
            <div class="max-w-6xl mx-auto px-4 md:px-8 py-12">
                <div class="grid md:grid-cols-[1fr_300px] gap-8 items-start">
                    <!-- Main column -->
                    <div class="space-y-6">
                        <!-- About -->
                        <section
                            class="bg-base-100 rounded-3xl shadow-sm border border-base-200 p-8"
                            aria-label="Sobre este lugar"
                        >
                            <h2
                                class="font-heading font-bold text-xl text-neutral mb-5 flex items-center gap-3"
                            >
                                <span
                                    class="w-8 h-8 rounded-xl bg-primary/10 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-4 h-4"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                        ></path></svg
                                    >
                                </span>
                                Sobre este lugar
                            </h2>
                            <p
                                class="text-base-content/80 text-base leading-relaxed"
                            >
                                {poi.description}
                            </p>
                        </section>

                        <!-- Tags -->
                        {
                            poi.tags?.length > 0 && (
                                <section class="bg-base-100 rounded-3xl shadow-sm border border-base-200 p-8" aria-label="Etiquetas">
                                    <h2 class="font-heading font-bold text-xl text-neutral mb-5 flex items-center gap-3">
                                        <span class="w-8 h-8 rounded-xl bg-secondary/10 flex items-center justify-center shrink-0">
                                            <svg
                                                class="w-4 h-4"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"
                                                />
                                            </svg>
                                        </span>
                                        Qué encontrarás
                                    </h2>
                                    <div class="flex flex-wrap gap-2.5">
                                        {poi.tags.map((tag: string) => (
                                            <span class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-xl bg-primary/5 text-base-content text-xs font-semibold border border-primary">
                                                <svg
                                                    class="w-2.5 h-2.5"
                                                    fill="currentColor"
                                                    viewBox="0 0 8 8"
                                                >
                                                    <circle
                                                        cx="4"
                                                        cy="4"
                                                        r="3"
                                                    />
                                                </svg>
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                </section>
                            )
                        }

                        <!-- Province banner -->
                        <div
                            class="rounded-3xl overflow-hidden shadow-sm border p-8"
                            style={`background:linear-gradient(135deg,${province.color}18 0%,${province.color}08 100%);border-color:${province.color}30`}
                        >
                            <div class="flex items-start gap-4">
                                <span
                                    class="w-12 h-12 rounded-2xl shrink-0 flex items-center justify-center"
                                    style={`background:${province.color}30`}
                                >
                                    <span
                                        class="w-5 h-5 rounded-full"
                                        style={`background:${province.color}`}
                                    ></span>
                                </span>
                                <div>
                                    <p
                                        class="text-xs uppercase tracking-wider font-semibold mb-0.5"
                                        style={`color:${province.color}`}
                                    >
                                        Provincia
                                    </p>
                                    <h3
                                        class="font-heading font-bold text-xl text-neutral mb-1"
                                    >
                                        {province.name}
                                    </h3>
                                    <p
                                        class="text-sm text-base-content/70 leading-relaxed"
                                    >
                                        {poi.name} está ubicado en la región <strong
                                            class="text-base-content"
                                            >{province.region}</strong
                                        > de la República Dominicana.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <PoiBentoGrid images={bentoImages} name={poi.name} />
                        
                        <Comments client:visible targetType="DESTINATION" targetId={poi.id} token={token} loginUrl={loginUrl} />
                    </div>

                    <!-- Sidebar -->
                    <PoiSidebar
                        poi={poi}
                        province={province}
                        hours={hours}
                        website={website}
                        mapLink={mapLink}
                        showHours={showHours}
                        token={token}
                        isLoggedIn={isLoggedIn}
                        isFavorited={isFavorited}
                        user={user}
                        loginUrl={loginUrl}
                    />
                </div>
            </div>
        </div>

        <PoiRelated related={related} />
        
    </article>
    </main>

</Layout>
