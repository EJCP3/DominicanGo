---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import BlogPostHero from "../../components/blog/BlogPostHero.astro";
import BlogPostContent from "../../components/blog/BlogPostContent.astro";
import BlogBentoGallery from "../../components/blog/BlogBentoGallery.astro";

import { getBlogs, getFavoriteIds } from "../../services/api";
import BotonFavorito from "../../components/ui/BotonFavorito.vue";

const token = Astro.cookies.get("auth_token")?.value ?? "";
const isLoggedIn = !!token;
const { slug } = Astro.params;

// Fetch dynamically
const { data } = await getBlogs({ slug: slug as string });
const post = data && data.length > 0 ? data[0] : null;

if (!post) {
    return Astro.redirect("/blog");
}

const dateToFormat = post.publishedAt || post.createdAt || new Date();
const formattedDate = new Date(dateToFormat).toLocaleDateString("es-DO", {
    day: "numeric",
    month: "short",
    year: "numeric",
});
const authorName = post.author?.name || "Viajero DominicanGo";
const destinationName = post.destination?.name || null;
const provinceId = post.provinceId || null;
const destinationSlug = post.destination?.slug || null;

const { blogIds: favBlogIds } = await getFavoriteIds(token);
const isFavorited = favBlogIds.has(post.id);
---

<Layout title={`${post.title} — Blog DominicanGo`}>
    <Header />

    <main class="min-h-screen pt-24 pb-24">
        <article class="max-w-4xl mx-auto px-4 sm:px-6">
            <BlogPostHero
                title={post.title}
                image={post.images[0]}
                slug={slug as string}
            />

            <BlogPostContent
                title={post.title}
                author={authorName}
                date={formattedDate}
                content={post.content}
                destinationName={destinationName}
                destinationSlug={destinationSlug}
                provinceId={provinceId}
                slug={slug as string}
                authorFoto={post.author?.foto}
            />

            <BlogBentoGallery images={post.images} title={post.title} />

            <div class="max-w-3xl mx-auto mt-16 pt-8 border-t border-base-200">
                <a
                    href="/blog"
                    class="btn btn-ghost text-base-content/60 hover:text-base-content mb-8"
                >
                    ← Volver al blog
                </a>

                <div
                    class="bg-base-100 rounded-3xl p-6 shadow-sm border border-base-200"
                >
                    <div
                        class="flex flex-col sm:flex-row gap-4 items-center justify-between"
                    >
                        <div>
                            <h3
                                class="font-heading font-bold text-lg text-base-content"
                            >
                                ¿Te gustó esta historia?
                            </h3>
                            <p class="text-sm text-base-content/60">
                                Guárdala en tus favoritos o compártela con otros
                                viajeros.
                            </p>
                        </div>
                        <div class="flex gap-3 items-center">
                            <button
                                class="btn btn-circle btn-ghost bg-base-200 hover:bg-white shadow-sm"
                                onclick="if(navigator.share) navigator.share({ title: document.title, url: window.location.href }).catch(()=>{}); else alert('Comparte copiando la URL: ' + window.location.href);"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
                                    ></path></svg
                                >
                            </button>

                            {
                                isLoggedIn && (
                                    <div class="relative w-12 h-12 flex items-center justify-center ">
                                        <BotonFavorito
                                            client:load
                                            itemId={post.id}
                                            type="blog"
                                            isLoggedIn={isLoggedIn}
                                            token={token}
                                            initialState={isFavorited}
                                        />
                                    </div>
                                )
                            }
                        </div>
                    </div>
                </div>
            </div>
        </article>
    </main>
</Layout>
