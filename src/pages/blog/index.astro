---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import BlogFiltersPanel from "../../components/blog/BlogFiltersPanel.astro";

import { getBlogs, getFavoriteIds } from "../../services/api";

const token = Astro.cookies.get("auth_token")?.value ?? "";
const isLoggedIn = !!token;
const { blogIds: favBlogIds } = await getFavoriteIds(token);
const currentCategory = Astro.url.searchParams.get("category") || undefined;

// Fetch dynamic data from backend API
const {
    data: posts,
    success,
    message = "",
} = await getBlogs({ category: currentCategory });
---

<Layout
    title="Blog de Viajeros — DominicanGo"
    description="Descubre increíbles historias de viajeros explorando la República Dominicana y comparte la tuya."
>
    <Header />

    <main class="min-h-screen pt-24 pb-16">
        <div class="max-w-[1400px] mx-auto px-4 sm:px-6">
            <!-- Hero / Header Section -->
            <div
                class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12"
            >
                <div>
                    <h1
                        class="font-heading font-extrabold text-4xl md:text-5xl text-base-content mb-3"
                    >
                        Diarios de <span class="text-primary">Viaje</span>
                    </h1>
                    <p class="text-base-content/70 max-w-2xl text-lg">
                        Historias auténticas, guías detalladas y narrativas
                        visuales de exploradores descubriendo cada rincón de
                        República Dominicana.
                    </p>
                </div>
                <a
                    transition:name="blog-title"
                    href="/blog/nuevo"
                    class="btn btn-primary rounded-full shadow-lg shrink-0"
                >
                    <svg
                        class="w-5 h-5 mr-1"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 4v16m8-8H4"></path></svg
                    >
                    Comparte tu experiencia
                </a>
            </div>

            <!-- Categories / Filter (Visual only for prototype) -->
            <div class="flex items-center gap-4 mb-10">
                <div class="relative z-50">
                    <button
                        id="btn-abrir-filtros"
                        class="btn btn-sm h-10 px-5 rounded-full bg-base-100 hover:bg-base-200 text-[#2F3D4E] font-bold border-base-300 shadow-sm flex items-center gap-2 shrink-0"
                        onclick="document.getElementById('blog-filtros-panel').classList.toggle('popup-open');"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
                            ></path>
                        </svg>
                        Filtros
                    </button>
                    <!-- Filter content pop-over (tooltip) component -->
                    <BlogFiltersPanel />
                </div>
            </div>

            <!-- Blog Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    posts.map((post) => (
                        <a
                            href={`/blog/${post.slug}`}
                            class="card bg-base-100 shadow-sm border border-base-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden group"
                        >
                            <figure class="aspect-4/3 overflow-hidden relative">
                                <img
                                    src={post.images[0]}
                                    alt={post.title}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                    transition:name={`img-blog-${post.slug}`}
                                />
                                <div class="absolute top-4 left-4 bg-base-100/90 backdrop-blur-sm px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-primary shadow-sm">
                                    {post.category}
                                </div>
                            </figure>
                            <div class="card-body p-6">
                                <h2
                                    transition:name={`title-blog-${post.slug}`}
                                    class="card-title font-heading font-bold text-xl leading-tight mb-2 group-hover:text-primary transition-colors"
                                >
                                    {post.title}
                                </h2>
                                <p class="text-base-content/70 text-sm line-clamp-3 italic">
                                    {post.excerpt}
                                </p>
                                <div class="mt-4 pt-4 border-t border-base-200 flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full overflow-hidden bg-primary/10 flex items-center justify-center ring-1 ring-base-200">
                                            {post.author?.foto ? (
                                                <img
                                                    src={post.author.foto}
                                                    alt={post.author.name}
                                                    class="w-full h-full object-cover"
                                                    referrerpolicy="no-referrer"
                                                />
                                            ) : (
                                                <span class="text-[10px] font-bold text-primary">
                                                    {post.author?.name?.charAt(
                                                        0,
                                                    )}
                                                </span>
                                            )}
                                        </div>
                                        <span class="text-xs font-semibold text-base-content/70">
                                            {post.author?.name || "Viajero"}
                                        </span>
                                    </div>
                                    <div class="flex items-center gap-3 text-[10px] text-base-content/40 font-medium">
                                        <span>
                                            {new Date(
                                                post.publishedAt ||
                                                    post.createdAt ||
                                                    new Date(),
                                            ).toLocaleDateString("es-DO", {
                                                day: "numeric",
                                                month: "short",
                                            })}
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>

            <div class="hidden" id="ssr-debug">
                DEBUG -- Category: {currentCategory} | Success: {
                    success ? "true" : "false"
                } | Posts length: {posts?.length} | Message: {message}
            </div>
        </div>
    </main>
</Layout>
