---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import GuardadosDashboard from "../components/usuario/GuardadosDashboard.vue";
import { getUser } from "../services/api";

// Auth guard
const token = Astro.cookies.get("auth_token")?.value ?? '';
const user = await getUser(token);
if (!user) {
    return Astro.redirect("/?error=auth_required");
}
---

<Layout
    title="Mis Viajes Guardados — DominicanGo"
    description="Tus destinos y diarios de viaje favoritos guardados para explorar más tarde."
>
    <Header />

    <main class="min-h-screen pt-24 pb-16 bg-[#FDFBF7]">
        <div class="max-w-[1400px] mx-auto px-4 sm:px-6">
            <GuardadosDashboard
                client:only="vue"
                token={token}
            />
        </div>
    </main>
</Layout>
