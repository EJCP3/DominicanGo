---
import "../styles/app.css";
import IconSprite from "../components/ui/IconSprite.astro";

import { ClientRouter } from "astro:transitions";
import ViewToggle from "../components/destinos/ViewToggle.astro";
import RandomDestinationPop from "../components/destinos/RandomDestinationPop.astro";

interface Props {
    title?: string;
    description?: string;
    showWidgets?: boolean;
}

const {
    title = "DominicanGo — Mapa Interactivo de República Dominicana",
    description = "Explora República Dominicana provincia por provincia. Guía turística interactiva con mapa, playas, montañas, cultura y aventura.",
    showWidgets = true,
} = Astro.props;
---

<html lang="es" data-theme="cupcake">
    <head>
        <meta charset="utf-8" />
        <ClientRouter />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <script is:inline>
            // Evita el flashazo blanco/oscuro aplicando el tema antes del render
            (function () {
                var theme = localStorage.getItem("theme");
                if (!theme) {
                    theme = "cupcake"; // Verano / default
                    localStorage.setItem("theme", theme);
                }
                document.documentElement.setAttribute("data-theme", theme);

                // Retener el tema durante Single Page Navigations (ViewTransitions)
                document.addEventListener("astro:after-swap", function () {
                    var currentTheme =
                        localStorage.getItem("theme") || "cupcake";
                    document.documentElement.setAttribute(
                        "data-theme",
                        currentTheme,
                    );
                });
            })();
        </script>
        <title>{title}</title>
    </head>
    <body class="font-body min-h-screen">
        <IconSprite />
        <slot />
        {
            showWidgets && (
                <>
                    <ViewToggle />
                    <RandomDestinationPop />
                </>
            )
        }
    </body>
</html>
