---
interface Props {
    title?: string;
    description?: string;
}

const {
    title = "DominicanGo — Mapa Interactivo de República Dominicana",
    description = "Explora República Dominicana provincia por provincia. Guía turística interactiva con mapa, playas, montañas, cultura y aventura.",
} = Astro.props;
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
        <style>
            @import "../styles/app.css";
        </style>
    </head>
    <body class="font-body min-h-screen">
        <slot />
    </body>
</html>
